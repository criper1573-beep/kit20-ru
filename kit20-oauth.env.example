# =============================================================================
# Kit20.ru — секреты для Decap CMS (GitHub OAuth) и деплоя OAuth на VPS
# =============================================================================
# 1) Скопируйте этот файл в kit20-oauth.env (в ту же папку, что и package.json).
# 2) Заполните только значения справа от = (без кавычек).
# 3) Запуск: powershell -ExecutionPolicy Bypass -File scripts\deploy-kit20-oauth.ps1
#
# Файл kit20-oauth.env в .gitignore — не отправляйте его в GitHub.
# =============================================================================

# Пароль SSH (латвийский VPS). Можно оставить пустым: скрипт возьмёт SERVER_LV_SSH_PASSWORD из Desktop\КонтентЗавод\.env
SERVER_LV_SSH_PASSWORD=6bnVj@WS3!Gn

# IP сервера (если не меняли — оставьте как есть)
SERVER_LV_HOST=194.113.209.152

# GitHub → Settings → Developer settings → OAuth Apps → ваше приложение kit20
# Client ID (виден сразу на странице приложения)
KIT20_GITHUB_OAUTH_CLIENT_ID=Ov23liLaBkKkXWG1Q3XC

# Client secrets → Generate new client secret (одна строка, копируется один раз)
KIT20_GITHUB_OAUTH_CLIENT_SECRET=d29c0d764eee58a0a49154d1d760bb05049c33d7
