---
import '../styles/global.css';
import StageBackdrop from '../components/StageBackdrop.astro';
import Ticker from '../components/Ticker.astro';
import FooterJumpGame from '../components/FooterJumpGame.astro';
import { readHome } from '../lib/siteContent';

interface Props {
	title: string;
	description?: string;
	/** Режим встроенной админки: те же экраны, но под `/admin` */
	admin?: boolean;
}

const { title, description = 'Сайт учебной группы театра и кино', admin = false } = Astro.props;

const pathname = Astro.url.pathname;
const showFooterGame = !admin;
const isClassRoute = pathname.startsWith('/class') || pathname.startsWith('/admin/class');

const homeTicker = await readHome().catch(() => null);
const tickerTop = homeTicker?.data.tickerTop ?? '';
const tickerBottom = homeTicker?.data.tickerBottom ?? '';

const links = admin
	? [
			{ href: '/admin', label: 'Главная', match: (p: string) => p === '/admin' || p === '/admin/' },
			{
				href: '/admin/class',
				label: 'Класс',
				match: (p: string) => p.startsWith('/admin/class') || p.startsWith('/admin/student'),
			},
			{ href: '/admin/attendance', label: 'Посещаемость', match: (p: string) => p.startsWith('/admin/attendance') },
			{ href: '/admin/obschak', label: 'Общак', match: (p: string) => p.startsWith('/admin/obschak') },
			{ href: '/admin/birthday-dial', label: 'ДР циферблат', match: (p: string) => p.startsWith('/admin/birthday-dial') },
			{ href: '/admin/logs', label: 'Логи', match: (p: string) => p.startsWith('/admin/logs') },
		]
	: [
			{ href: '/', label: 'Главная', match: (p: string) => p === '/' },
			{ href: '/class', label: 'Класс', match: (p: string) => p.startsWith('/class') },
			{ href: '/attendance', label: 'Посещаемость', match: (p: string) => p.startsWith('/attendance') },
			{ href: '/obshchak', label: 'Общак', match: (p: string) => p.startsWith('/obshchak') },
			{ href: '/dni-rozhdeniya', label: 'Дни рождения', match: (p: string) => p.startsWith('/dni-rozhdeniya') },
		];
---

<!doctype html>
<html lang="ru">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body class="relative overflow-x-hidden bg-canvas font-sans text-ink antialiased">
		<StageBackdrop gridOnly={isClassRoute} />
		<div class="relative z-10 flex min-h-dvh flex-col pb-[var(--site-ticker-h)]">
			<div class="sticky top-0 z-40 bg-canvas">
				<header
					class="site-header flex h-14 items-center gap-0 overflow-visible border-b-[3px] border-accent bg-ink pr-1 text-canvas sm:pr-2"
				>
					<div
						class="glitch-brand-wrap flex h-full min-w-0 w-[5.2rem] shrink-0 select-none items-center justify-center bg-accent px-2 font-display tracking-[0.12em] text-canvas sm:w-auto sm:px-5"
					>
						<a href={admin ? '/admin' : '/'} class="text-canvas no-underline">
							<span class="glitch-brand text-2xl sm:text-3xl" data-text="КИТ20">КИТ20</span>
						</a>
					</div>
					<div class="ml-auto flex h-full flex-1 items-center justify-end gap-0 sm:gap-1">
						{
							admin && (
								<span class="hidden max-w-0 font-display text-base tracking-widest text-[#555] sm:mr-2 sm:max-w-none sm:inline sm:text-lg">
									АДМИН
								</span>
							)
						}
						{
							admin ? (
								<a
									href="/"
									class="hidden px-2 text-[10px] uppercase tracking-widest text-muted transition-colors hover:text-canvas sm:inline"
								>
									На сайт
								</a>
							) : (
								<span class="hidden font-display text-xl tracking-widest text-[#333] sm:inline sm:text-2xl">01</span>
							)
						}
						<button
							type="button"
							class="site-nav-toggle flex h-14 w-12 flex-col items-center justify-center gap-[5px] border-l border-[#222] bg-transparent px-2 text-canvas sm:w-14"
							aria-expanded="false"
							aria-controls="site-nav-panel"
							aria-label="Открыть меню"
						>
							<span class="burger-line block h-0.5 w-5 origin-center bg-canvas transition-transform duration-200"></span>
							<span class="burger-line block h-0.5 w-5 bg-canvas transition-opacity duration-200"></span>
							<span class="burger-line block h-0.5 w-5 origin-center bg-canvas transition-transform duration-200"></span>
						</button>
					</div>
				</header>
				<nav
					id="site-nav-panel"
					class="site-nav-panel hidden border-b border-[#1a1a1a] bg-ink text-canvas"
					aria-label="Основная навигация"
					hidden
				>
					<ul class="flex flex-col py-1">
						{
							links.map(({ href, label, match }) => (
								<li class="border-b border-[#222] last:border-0">
									<a
										href={href}
										class:list={[
											'block w-full py-3.5 pl-5 pr-4 font-mono text-xs uppercase tracking-[0.2em] transition-colors sm:py-4 sm:pl-8 sm:text-sm',
											match(pathname)
												? 'bg-[#1a1a1a] text-canvas'
												: 'text-muted hover:bg-[#252525] hover:text-canvas',
										]}
									>
										{label}
									</a>
								</li>
							))
						}
					</ul>
				</nav>
				<style is:global>
					.site-nav-toggle--open .burger-line:nth-child(1) {
						transform: translateY(7px) rotate(45deg);
					}
					.site-nav-toggle--open .burger-line:nth-child(2) {
						opacity: 0;
					}
					.site-nav-toggle--open .burger-line:nth-child(3) {
						transform: translateY(-7px) rotate(-45deg);
					}
					#site-nav-panel:not([hidden]) {
						max-height: min(60vh, 28rem);
						overflow-y: auto;
					}
				</style>
				<script is:inline>
					(function () {
						var btn = document.querySelector('.site-nav-toggle');
						var panel = document.getElementById('site-nav-panel');
						if (!btn || !panel) return;
						var open = false;
						function setOpen(should) {
							open = should;
							btn.setAttribute('aria-expanded', should ? 'true' : 'false');
							btn.setAttribute('aria-label', should ? 'Закрыть меню' : 'Открыть меню');
							btn.classList.toggle('site-nav-toggle--open', should);
							if (should) {
								panel.removeAttribute('hidden');
								panel.classList.remove('hidden');
							} else {
								panel.setAttribute('hidden', '');
								panel.classList.add('hidden');
							}
						}
						btn.addEventListener('click', function (e) {
							e.stopPropagation();
							setOpen(!open);
						});
						panel.querySelectorAll('a').forEach(function (a) {
							a.addEventListener('click', function () {
								setOpen(false);
							});
						});
						document.addEventListener('click', function (e) {
							if (!open) return;
							var t = e.target;
							if (btn.contains(t) || panel.contains(t)) return;
							setOpen(false);
						});
						document.addEventListener('keydown', function (e) {
							if (e.key === 'Escape' && open) setOpen(false);
						});
					})();
				</script>
				<Ticker band="top" text={tickerTop} />
			</div>
			<main class="mx-auto w-full max-w-5xl flex-1 px-4 py-8 sm:px-6 sm:py-10">
				<slot />
			</main>
			<footer
				class:list={[
					'mt-auto grid grid-cols-1 gap-6 border-t-[4px] border-accent bg-ink px-5 py-6 text-canvas sm:px-8 sm:py-7',
					showFooterGame ? 'sm:grid-cols-3' : 'sm:grid-cols-2',
				]}
			>
				<div>
					<h3 class="mb-2 font-display text-2xl tracking-wide sm:text-3xl">КИТ 20</h3>
					<p class="text-[10px] leading-relaxed text-[#666]">
						Учебная группа театра и кино · Парт Академии
					</p>
					<div class="mt-2 font-mono text-[11px] text-accent">kit20.ru</div>
				</div>
				{
					showFooterGame && (
						<div class="sm:mx-auto sm:w-full sm:max-w-[24rem]">
							<FooterJumpGame />
						</div>
					)
				}
				<div class="flex flex-col justify-between gap-3 sm:items-end sm:text-right">
					{
						!admin && (
							<a
								href="https://t.me/VAZHEVA_AA"
								target="_blank"
								rel="noopener noreferrer"
								class="type-cta inline-flex items-center justify-center border-[3px] border-ink bg-accent px-4 py-2 text-[11px] tracking-[0.14em] text-canvas shadow-[var(--shadow-card)] transition-colors hover:bg-accent-hover sm:self-end"
							>
								Написать старосте
							</a>
						)
					}
					<p class="text-[10px] leading-relaxed text-[#666]">
						{
							admin ? (
								<form method="POST" action="/api/admin/logout" class="flex sm:justify-end">
									<button
										type="submit"
										class="type-cta uppercase tracking-widest text-accent transition-colors hover:text-accent-hover"
									>
										Выйти из админки
									</button>
								</form>
							) : (
								<a href="/admin" class="uppercase tracking-widest text-muted transition-colors hover:text-canvas">
									Вход для администратора
								</a>
							)
						}
					</p>
					<p class="font-mono text-[10px] tracking-widest text-[#444]">2026–2028</p>
				</div>
				<div class:list={['col-span-1 border-t border-[#1a1a1a] pt-4 text-center text-[9px] tracking-[0.2em] text-[#444]', showFooterGame ? 'sm:col-span-3' : 'sm:col-span-2']}>
					КИТ20 · Парт Академия · театр и кино
				</div>
			</footer>
		</div>
		<Ticker band="bottom" text={tickerBottom} />
		{
			!admin && (
				<>
					<!-- Yandex.Metrika counter -->
					<script is:inline>
						(function (m, e, t, r, i, k, a) {
							m[i] =
								m[i] ||
								function () {
									(m[i].a = m[i].a || []).push(arguments);
								};
							m[i].l = 1 * new Date();
							for (var j = 0; j < document.scripts.length; j++) {
								if (document.scripts[j].src === r) {
									return;
								}
							}
							k = e.createElement(t);
							a = e.getElementsByTagName(t)[0];
							k.async = 1;
							k.src = r;
							a.parentNode.insertBefore(k, a);
						})(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js?id=108705431', 'ym');
						ym(108705431, 'init', {
							ssr: true,
							webvisor: true,
							clickmap: true,
							ecommerce: 'dataLayer',
							referrer: document.referrer,
							url: location.href,
							accurateTrackBounce: true,
							trackLinks: true,
						});
					</script>
					<noscript>
						<div>
							<img
								src="https://mc.yandex.ru/watch/108705431"
								style="position:absolute; left:-9999px;"
								alt=""
							/>
						</div>
					</noscript>
					<!-- /Yandex.Metrika counter -->
				</>
			)
		}
	</body>
</html>
