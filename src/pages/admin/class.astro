---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import ClassPageOverlay from '../../components/ClassPageOverlay.astro';
import StudentAvatar from '../../components/StudentAvatar.astro';
import { readStudentsSorted } from '../../lib/siteContent';
import { renderMarkdownToHtml } from '../../lib/renderMarkdown';
import { hasValidAdminSession } from '../../lib/adminApiAuth';

if (!hasValidAdminSession(Astro.cookies)) {
	const nextUrl = Astro.url.pathname + Astro.url.search;
	return Astro.redirect(`/admin/login?next=${encodeURIComponent(nextUrl)}`);
}

const rows = await readStudentsSorted();

const blocks = rows.map((entry, i) => ({
	slug: entry.data.slug,
	data: entry.data,
	bodyHtml: renderMarkdownToHtml(entry.body),
	variant: i,
}));

const stageBlocks = blocks.map(({ slug, data, variant }) => ({
	slug,
	data: { displayName: data.displayName },
	variant,
}));
---

<Layout admin title="Класс · редактирование">
	<ClassPageOverlay
		slot="class-overlay"
		blocks={stageBlocks}
		pageLead="Нажмите на фигуру, как на сайте. В карточке есть ссылка «Редактировать данные»."
	/>
	<div class="min-h-[min(88vh,52rem)] w-full" aria-hidden="true"></div>
	{
		blocks.map(({ slug, data, bodyHtml, variant }) => (
			<dialog
				id={`dlg-${slug}`}
				class="fixed left-1/2 top-1/2 z-[100] w-[min(100vw-2rem,28rem)] max-w-[calc(100vw-2rem)] -translate-x-1/2 -translate-y-1/2 overflow-hidden rounded-shell border border-theme bg-surface p-0 text-ink shadow-[var(--shadow-float)]"
			>
				<div class="border-b border-theme-subtle bg-muted-surface px-5 py-4">
					<div class="flex flex-wrap items-start justify-between gap-3">
						<div>
							<h2 class="font-display text-xl font-normal text-ink sm:text-2xl">{data.displayName}</h2>
							{data.fullName && <p class="text-sm text-muted">{data.fullName}</p>}
						</div>
						<div class="flex flex-wrap gap-2">
							<a
								href={`/admin/student/${slug}`}
								class="type-cta border-[3px] border-ink bg-accent px-3 py-2 text-sm text-canvas shadow-[var(--shadow-card)] hover:bg-accent-hover"
							>
								Редактировать данные
							</a>
							<button
								type="button"
								class="type-cta border-[3px] border-ink bg-surface px-3 py-2 text-sm text-ink shadow-[var(--shadow-card)] hover:bg-muted-surface"
								data-close-dialog=""
							>
								Закрыть
							</button>
						</div>
					</div>
				</div>
				<div class="max-h-[min(70vh,32rem)] overflow-y-auto px-5 py-4">
					<div class="mb-5 flex gap-4">
						<div class="h-24 w-20 shrink-0">
							<StudentAvatar variant={variant} displayName={data.displayName} class="h-full w-full" />
						</div>
						<dl class="grid flex-1 gap-2 text-sm">
							{data.fullName && (
								<div class="flex justify-between gap-4 border-b border-theme-subtle py-1.5">
									<dt class="text-muted">ФИО</dt>
									<dd class="text-right font-medium text-ink">{data.fullName}</dd>
								</div>
							)}
							{data.birthday && (
								<div class="flex justify-between gap-4 border-b border-theme-subtle py-1.5">
									<dt class="text-muted">День рождения</dt>
									<dd class="text-right font-medium text-ink">{data.birthday}</dd>
								</div>
							)}
							{data.nickname && (
								<div class="flex justify-between gap-4 border-b border-theme-subtle py-1.5">
									<dt class="text-muted">Псевдоним</dt>
									<dd class="text-right font-medium text-ink">{data.nickname}</dd>
								</div>
							)}
							{data.phone && (
								<div class="flex justify-between gap-4 border-b border-theme-subtle py-1.5">
									<dt class="text-muted">Телефон</dt>
									<dd class="text-right font-medium text-ink">{data.phone}</dd>
								</div>
							)}
						</dl>
					</div>
					{data.photo && (
						<img
							src={data.photo}
							alt=""
							class="mb-5 max-h-48 w-full rounded-xl border border-theme object-cover object-top shadow-sm"
							loading="lazy"
						/>
					)}
					{data.etudes.length > 0 && (
						<>
							<h3 class="mb-2 font-display text-base font-normal text-accent">Этюды</h3>
							<ul class="space-y-3">
								{data.etudes.map((e) => (
									<li class="kit-etude-card" tabindex="0">
										<div class="flex flex-wrap items-center justify-between gap-2">
											<span class="kit-etude-shift kit-etude-shift--title uppercase text-ink">{e.title}</span>
											<span
												class:list={[
													'kit-etude-shift kit-etude-shift--badge border-[2px] border-ink px-2 py-0.5 text-xs uppercase',
													e.passed ? 'bg-accent text-canvas' : 'bg-muted-surface text-ink',
												]}
											>
												{e.passed ? 'Сдан' : 'Не сдан'}
											</span>
										</div>
										{e.date && (
											<p class="kit-etude-shift kit-etude-shift--date mt-2 text-xs font-bold text-muted">{e.date}</p>
										)}
									</li>
								))}
							</ul>
						</>
					)}
					<div class="markdown-body mt-6 border-t border-theme-subtle pt-5 text-sm" set:html={bodyHtml} />
				</div>
			</dialog>
		))
	}

	<script is:inline>
		document.querySelectorAll('[data-open-dialog]').forEach((btn) => {
			btn.addEventListener('click', () => {
				const id = btn.getAttribute('data-open-dialog');
				if (id?.startsWith('dlg-')) {
					const slug = id.slice(4);
					document.querySelectorAll(`[data-stage-slug="${slug}"]`).forEach((el) => {
						el.classList.add('class-stage-figure-pulse');
						window.setTimeout(() => el.classList.remove('class-stage-figure-pulse'), 780);
					});
				}
				const dlg = id ? document.getElementById(id) : null;
				if (dlg instanceof HTMLDialogElement) dlg.showModal();
			});
		});
		document.querySelectorAll('[data-close-dialog]').forEach((btn) => {
			btn.addEventListener('click', () => {
				const dlg = btn.closest('dialog');
				dlg?.close();
			});
		});
		document.querySelectorAll('dialog').forEach((dlg) => {
			dlg.addEventListener('click', (e) => {
				if (e.target === dlg) dlg.close();
			});
		});
	</script>
</Layout>
