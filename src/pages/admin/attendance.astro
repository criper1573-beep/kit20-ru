---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { readStudentsSorted, readAttendance } from '../../lib/siteContent';
import { hasValidAdminSession } from '../../lib/adminApiAuth';

if (!hasValidAdminSession(Astro.cookies)) {
	const nextUrl = Astro.url.pathname + Astro.url.search;
	return Astro.redirect(`/admin/login?next=${encodeURIComponent(nextUrl)}`);
}

const students = await readStudentsSorted();
const { data: att } = await readAttendance();


// Сортируем занятия: самые новые слева (по убыванию даты)
const lessons = (att.lessons ?? []).sort((a, b) => {
	return new Date(b.date).getTime() - new Date(a.date).getTime();
});

type CellState = 'present' | 'absent';

function cellStatus(lesson: (typeof lessons)[number], slug: string): CellState {
	const legacy = lesson.records;
	if (legacy && legacy.length > 0) {
		const r = legacy.find((x) => x.student === slug);
		if (r?.status === 'absent') return 'absent';
		return 'present';
	}
	const ex = lesson.exceptions?.find((x) => x.student === slug);
	if (!ex) return 'present';
	if (ex.status === 'excused') return 'present';
	return 'absent';
}

const initialJson = JSON.stringify({ lessons });
---

<Layout admin title="Посещаемость · редактирование">
	<div class="mb-8 border-b-[3px] border-ink pb-4 flex flex-wrap items-center justify-between gap-4">
		<div>
			<h1 class="font-display text-4xl font-normal tracking-widest text-ink sm:text-5xl uppercase">Посещаемость</h1>
			<p class="mt-2 font-sans text-sm uppercase tracking-wider text-muted">
				Нажмите на ячейку, чтобы отметить отсутствие (Н). Ещё раз — снова «был» (Б).
			</p>
		</div>
		<button
			type="button"
			id="add-lesson-btn"
			class="border-[3px] border-ink bg-surface px-4 py-2 font-sans text-sm uppercase tracking-widest text-ink shadow-[var(--shadow-card)] hover:bg-accent hover:text-canvas active-shift transition-colors flex items-center gap-2"
		>
			<span class="text-xl leading-none">+</span> Урок
		</button>
	</div>

	<div
		class="bb-scrollbar overflow-x-auto border-[3px] border-ink bg-surface shadow-[var(--shadow-card)]"
		style="--att-name-col-w:5.6rem; --att-name-col-w-sm:6.4rem; --att-cell-w:5.6rem; --att-cell-w-sm:6.4rem;"
	>
		<table class="w-max table-fixed border-collapse text-left font-sans text-[10px] sm:text-sm" id="att-table">
			<thead>
				<tr class="border-b-[3px] border-ink bg-ink text-canvas">
					<th class="sticky left-0 z-10 w-[var(--att-name-col-w)] min-w-[var(--att-name-col-w)] max-w-[var(--att-name-col-w)] overflow-hidden border-r-[3px] border-ink bg-ink px-1 py-2 text-[11px] font-display font-normal tracking-normal sm:w-[var(--att-name-col-w-sm)] sm:min-w-[var(--att-name-col-w-sm)] sm:max-w-[var(--att-name-col-w-sm)] sm:px-4 sm:py-3.5 sm:text-xl sm:tracking-widest">
						УЧЕНИК
					</th>
					{lessons.map((lesson, li) => (
					<th class="w-[var(--att-cell-w)] min-w-[var(--att-cell-w)] max-w-[var(--att-cell-w)] overflow-hidden border-r-[2px] border-ink/20 px-0.5 py-2 text-center last:border-r-[3px] last:border-ink relative group/th sm:w-[var(--att-cell-w-sm)] sm:min-w-[var(--att-cell-w-sm)] sm:max-w-[var(--att-cell-w-sm)] sm:px-0.5 sm:py-2">
						<button type="button" class="remove-lesson-btn absolute right-1 top-1 hidden h-4 w-4 items-center justify-center text-[10px] text-accent hover:bg-accent hover:text-canvas group-hover/th:flex" data-li={String(li)} title="Удалить занятие">✕</button>
						<div class="text-[10px] text-accent cursor-pointer hover:underline sm:text-xs" data-edit-date data-li={String(li)} title="Изменить дату">{lesson.date}</div>
						<div class="mt-0.5 text-[9px] uppercase tracking-[0.08em] text-canvas/70 cursor-pointer hover:underline sm:mt-1 sm:text-[10px] sm:tracking-wider" data-edit-label data-li={String(li)} title="Изменить название">
							{lesson.label || '—'}
						</div>
					</th>
					))}
				</tr>
			</thead>
			<tbody>
				{students.map((s) => (
					<tr class="border-b-[2px] border-ink/20 last:border-0 hover:bg-muted-surface transition-colors" data-slug={s.data.slug}>
						<td class="sticky left-0 z-10 w-[var(--att-name-col-w)] min-w-[var(--att-name-col-w)] max-w-[var(--att-name-col-w)] overflow-hidden text-ellipsis whitespace-nowrap border-r-[3px] border-ink bg-surface px-1 py-2 uppercase tracking-normal text-ink group-hover:bg-muted-surface transition-colors sm:w-[var(--att-name-col-w-sm)] sm:min-w-[var(--att-name-col-w-sm)] sm:max-w-[var(--att-name-col-w-sm)] sm:px-4 sm:py-3 sm:tracking-wider">
							{s.data.displayName}
						</td>
						{lessons.map((lesson, li) => {
							const st = cellStatus(lesson, s.data.slug);
							const absent = st === 'absent';
							const label = absent ? 'Н' : 'Б';
							return (
								<td class="w-[var(--att-cell-w)] min-w-[var(--att-cell-w)] max-w-[var(--att-cell-w)] overflow-hidden border-r-[2px] border-ink/20 px-0.5 py-2 text-center last:border-r-[3px] last:border-ink sm:w-[var(--att-cell-w-sm)] sm:min-w-[var(--att-cell-w-sm)] sm:max-w-[var(--att-cell-w-sm)] sm:px-0.5 sm:py-2">
									<button
										type="button"
										class:list={[
											'cell-att inline-flex min-w-[1.4rem] justify-center border-[2px] border-ink px-0.5 py-0.5 text-[10px] transition-colors active-shift sm:min-w-[1.6rem] sm:px-0.5 sm:py-0.5 sm:text-[10px]',
											absent ? 'bg-surface text-ink' : 'bg-accent text-canvas',
										]}
										data-li={String(li)}
										data-slug={s.data.slug}
										data-absent={absent ? '1' : '0'}
									>
										{label}
									</button>
								</td>
							);
						})}
					</tr>
				))}
			</tbody>
		</table>
	</div>

	<div class="mt-8 flex flex-wrap items-center gap-4">
		<button
			type="button"
			id="att-save"
			class="border-[3px] border-ink bg-accent px-6 py-3 font-display text-xl tracking-widest text-canvas shadow-[var(--shadow-card)] hover:bg-accent-hover active-shift transition-colors"
		>
			Сохранить посещаемость
		</button>
		<span id="att-status" class="font-sans text-sm uppercase text-muted"></span>
	</div>

	<script id="att-initial" type="application/json" set:html={initialJson} />

	<script>
		const dbgTable = document.getElementById('att-table');
		const dbgWrapper = dbgTable?.closest('.bb-scrollbar') as HTMLElement | null;
		const dbgHeadRow = dbgTable?.querySelector('thead tr');
		const dbgFirstHead = dbgHeadRow?.children?.[0] as HTMLElement | undefined;
		const dbgSecondHead = dbgHeadRow?.children?.[1] as HTMLElement | undefined;
		const dbgFirstData = dbgTable?.querySelector('tbody tr td') as HTMLElement | null;
		// #region agent log
		const debugPayload = {sessionId:'cdc693',runId:'attendance-width-v2',hypothesisId:'H1_H2_H4_H9',location:'src/pages/admin/attendance.astro:script',message:'Admin attendance runtime width snapshot',data:{viewportWidth:window.innerWidth,isSm:window.matchMedia('(min-width: 640px)').matches,cssVarNameCol:dbgWrapper?getComputedStyle(dbgWrapper).getPropertyValue('--att-name-col-w').trim():'',cssVarNameColSm:dbgWrapper?getComputedStyle(dbgWrapper).getPropertyValue('--att-name-col-w-sm').trim():'',tableClientWidth:dbgTable?.clientWidth??null,tableScrollWidth:dbgTable?.scrollWidth??null,wrapperClientWidth:dbgWrapper?.clientWidth??null,wrapperScrollWidth:dbgWrapper?.scrollWidth??null,firstHeadClientWidth:dbgFirstHead?.clientWidth??null,firstHeadScrollWidth:dbgFirstHead?.scrollWidth??null,secondHeadClientWidth:dbgSecondHead?.clientWidth??null,secondHeadScrollWidth:dbgSecondHead?.scrollWidth??null,firstDataClientWidth:dbgFirstData?.clientWidth??null,firstDataScrollWidth:dbgFirstData?.scrollWidth??null,firstDataText:dbgFirstData?.textContent?.trim()?.slice(0,32)??''},timestamp:Date.now()};
		fetch('http://127.0.0.1:7285/ingest/cd037db6-f3b9-4893-a32f-5e239cf83106',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'cdc693'},body:JSON.stringify(debugPayload)}).catch(()=>{});
		fetch('/api/debug/log',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(debugPayload)}).catch(()=>{});
		// #endregion
		const initialEl = document.getElementById('att-initial');
		const saveBtn = document.getElementById('att-save');
		const status = document.getElementById('att-status');
		const addLessonBtn = document.getElementById('add-lesson-btn');
		let autosaveTimer: number | null = null;
		let saveRequestId = 0;
		let latestSavedId = 0;

		function readInitial(): { lessons: { date: string; label?: string; exceptions?: { student: string }[] }[] } {
			if (!initialEl?.textContent) return { lessons: [] };
			return JSON.parse(initialEl.textContent);
		}

		function reindexLessons() {
			const headerCells = Array.from(document.querySelectorAll('#att-table thead tr th')).slice(1);
			headerCells.forEach((th, i) => {
				th.querySelectorAll('[data-li]').forEach((el) => {
					el.setAttribute('data-li', String(i));
				});
			});

			document.querySelectorAll('#att-table tbody tr').forEach((tr) => {
				const dataCells = Array.from(tr.children).slice(1);
				dataCells.forEach((td, i) => {
					const btn = td.querySelector('.cell-att');
					if (btn) btn.setAttribute('data-li', String(i));
				});
			});
		}

		function bindCellEvents() {
			document.querySelectorAll('.cell-att').forEach((el) => {
				const btn = el as HTMLButtonElement;
				// Remove old listeners to prevent duplicates
				const newBtn = btn.cloneNode(true) as HTMLButtonElement;
				btn.replaceWith(newBtn);
				
				newBtn.addEventListener('click', () => {
					const absent = newBtn.getAttribute('data-absent') === '1';
					const next = absent ? '0' : '1';
					newBtn.setAttribute('data-absent', next);
					newBtn.textContent = next === '1' ? 'Н' : 'Б';
					newBtn.classList.toggle('bg-surface', next === '1');
					newBtn.classList.toggle('text-ink', next === '1');
					newBtn.classList.toggle('bg-accent', next === '0');
					newBtn.classList.toggle('text-canvas', next === '0');
					scheduleAutoSave();
				});
			});
		}

		function bindEditEvents() {
			document.querySelectorAll('[data-edit-date]').forEach(el => {
				const div = el as HTMLDivElement;
				const newDiv = div.cloneNode(true) as HTMLDivElement;
				div.replaceWith(newDiv);
				
				newDiv.addEventListener('click', () => {
					const current = newDiv.textContent?.trim() || '';
					const val = prompt('Дата (YYYY-MM-DD):', current);
					if (val !== null && val.trim() !== '') {
						newDiv.textContent = val.trim();
						scheduleAutoSave();
					}
				});
			});

			document.querySelectorAll('[data-edit-label]').forEach(el => {
				const div = el as HTMLDivElement;
				const newDiv = div.cloneNode(true) as HTMLDivElement;
				div.replaceWith(newDiv);
				
				newDiv.addEventListener('click', () => {
					const current = newDiv.textContent?.trim() === '—' ? '' : newDiv.textContent?.trim() || '';
					const val = prompt('Название (необязательно):', current);
					if (val !== null) {
						newDiv.textContent = val.trim() || '—';
						scheduleAutoSave();
					}
				});
			});

			document.querySelectorAll('.remove-lesson-btn').forEach(btn => {
				const b = btn as HTMLButtonElement;
				const newB = b.cloneNode(true) as HTMLButtonElement;
				b.replaceWith(newB);

				newB.addEventListener('click', () => {
					const li = newB.getAttribute('data-li');
					if (!li || !confirm('Точно удалить это занятие?')) return;
					
					// Удаляем заголовок столбца
					const th = newB.closest('th');
					if (th) {
						const tr = th.parentElement;
						if (tr) {
							const colIndex = Array.from(tr.children).indexOf(th);
							th.remove();
							// Удаляем ячейки в этом столбце
							document.querySelectorAll('#att-table tbody tr').forEach(tbodyTr => {
								if (tbodyTr.children[colIndex]) {
									tbodyTr.children[colIndex].remove();
								}
							});
							reindexLessons();
							bindEditEvents();
							scheduleAutoSave();
						}
					}
				});
			});
		}

		function collectPayload() {
			const headerDates = Array.from(document.querySelectorAll('[data-edit-date]')).map(
				(el) => el.textContent?.trim() || ''
			);
			const headerLabels = Array.from(document.querySelectorAll('[data-edit-label]')).map((el) => {
				const t = el.textContent?.trim() || '';
				return t === '—' ? '' : t;
			});

			const byLesson: Map<number, Set<string>> = new Map();
			document.querySelectorAll('.cell-att').forEach((el) => {
				const btn = el as HTMLButtonElement;
				const li = Number(btn.dataset.li);
				const slug = btn.dataset.slug;
				if (!Number.isFinite(li) || !slug) return;
				if (btn.getAttribute('data-absent') !== '1') return;
				if (!byLesson.has(li)) byLesson.set(li, new Set());
				byLesson.get(li)!.add(slug);
			});

			const lessons = headerDates.map((date, i) => {
				const absentSlugs = byLesson.get(i);
				const exceptions = absentSlugs
					? [...absentSlugs].sort((a, b) => a.localeCompare(b, 'ru')).map((student) => ({ student }))
					: [];
				return {
					date,
					label: headerLabels[i] || '',
					exceptions,
				};
			});

			return {
				lessons,
				body: '',
			};
		}

		async function persistAttendance(mode: 'manual' | 'auto') {
			if (!status) return false;
			const requestId = ++saveRequestId;
			status.textContent = mode === 'manual' ? 'Сохраняю…' : 'Автосохранение…';
			const res = await fetch('/api/admin/attendance', {
				method: 'PUT',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(collectPayload()),
			});
			const j = await res.json().catch(() => ({}));
			if (requestId < latestSavedId) return false;
			if (!res.ok) {
				status.textContent = j.error ? JSON.stringify(j.error) : 'Ошибка';
				return false;
			}
			latestSavedId = requestId;
			status.textContent = mode === 'manual' ? 'Сохранено.' : 'Автосохранено.';
			return true;
		}

		function scheduleAutoSave() {
			if (autosaveTimer) window.clearTimeout(autosaveTimer);
			autosaveTimer = window.setTimeout(() => {
				persistAttendance('auto');
			}, 700);
		}

		bindCellEvents();
		bindEditEvents();

		// Crosshair highlight
		const table = document.getElementById('att-table');
		if (table) {
			const tbody = table.querySelector('tbody');
			const thead = table.querySelector('thead');
			if (tbody && thead) {
				let activeRowHeader = null;
				let activeColHeader = null;

				function clearHighlight() {
					if (activeRowHeader) activeRowHeader.classList.remove('is-crosshair-highlight');
					if (activeColHeader) activeColHeader.classList.remove('is-crosshair-highlight');
					activeRowHeader = null;
					activeColHeader = null;
				}

				function activateByCell(td) {
					const tr = td.closest('tr');
					if (!tr) return;
					const colIndex = Array.from(tr.children).indexOf(td);
					if (colIndex <= 0) return;
					clearHighlight();
					activeRowHeader = tr.children[0];
					const theadRow = thead.querySelector('tr');
					activeColHeader = theadRow ? theadRow.children[colIndex] : null;

					if (activeRowHeader) activeRowHeader.classList.add('is-crosshair-highlight');
					if (activeColHeader) activeColHeader.classList.add('is-crosshair-highlight');
				}

				const isTouchUi = window.matchMedia('(hover: none), (pointer: coarse)').matches;

				tbody.addEventListener('mouseover', (e) => {
					if (isTouchUi) return;
					const td = e.target.closest('td');
					if (!td) return;
					activateByCell(td);
				});

				tbody.addEventListener('mouseleave', () => {
					if (isTouchUi) return;
					clearHighlight();
				});

				tbody.addEventListener('click', (e) => {
					if (!isTouchUi) return;
					const td = e.target.closest('td');
					if (!td) return;
					activateByCell(td);
				});
			}
		}

		addLessonBtn?.addEventListener('click', () => {
			const date = prompt('Дата нового урока (YYYY-MM-DD):', new Date().toISOString().slice(0, 10));
			if (!date) return;
			const label = prompt('Название (необязательно):', '');
			
			const initial = readInitial();
			const newIndex = initial.lessons.length;
			initial.lessons.push({ date, label: label || undefined });
			if (initialEl) initialEl.textContent = JSON.stringify(initial);

			const theadTr = document.querySelector('#att-table thead tr');
			if (theadTr) {
				const th = document.createElement('th');
				th.className = "w-[var(--att-cell-w)] min-w-[var(--att-cell-w)] max-w-[var(--att-cell-w)] overflow-hidden border-r-[2px] border-ink/20 px-0.5 py-2 text-center last:border-r-0 relative group/th sm:w-[var(--att-cell-w-sm)] sm:min-w-[var(--att-cell-w-sm)] sm:max-w-[var(--att-cell-w-sm)] sm:px-0.5 sm:py-2";
				th.innerHTML = `
					<button type="button" class="remove-lesson-btn absolute right-1 top-1 hidden h-4 w-4 items-center justify-center text-[10px] text-accent hover:bg-accent hover:text-canvas group-hover/th:flex" data-li="${newIndex}" title="Удалить занятие">✕</button>
					<div class="text-xs text-accent cursor-pointer hover:underline" data-edit-date data-li="${newIndex}" title="Изменить дату">${date}</div>
					<div class="mt-1 text-[10px] uppercase tracking-wider text-canvas/70 cursor-pointer hover:underline" data-edit-label data-li="${newIndex}" title="Изменить название">${label || '—'}</div>
				`;
				theadTr.appendChild(th);
			}

			document.querySelectorAll('#att-table tbody tr').forEach(tr => {
				const slug = tr.getAttribute('data-slug');
				const td = document.createElement('td');
				td.className = "w-[var(--att-cell-w)] min-w-[var(--att-cell-w)] max-w-[var(--att-cell-w)] overflow-hidden border-r-[2px] border-ink/20 px-0.5 py-2 text-center last:border-r-0 sm:w-[var(--att-cell-w-sm)] sm:min-w-[var(--att-cell-w-sm)] sm:max-w-[var(--att-cell-w-sm)] sm:px-0.5 sm:py-2";
				td.innerHTML = `
					<button
						type="button"
						class="cell-att inline-flex min-w-[1.4rem] justify-center border-[2px] border-ink px-0.5 py-0.5 text-[10px] transition-colors active-shift bg-accent text-canvas"
						data-li="${newIndex}"
						data-slug="${slug}"
						data-absent="0"
					>Б</button>
				`;
				tr.appendChild(td);
			});

			reindexLessons();
			bindCellEvents();
			bindEditEvents();
			scheduleAutoSave();
		});

		saveBtn?.addEventListener('click', async () => {
			await persistAttendance('manual');
		});
	</script>
</Layout>