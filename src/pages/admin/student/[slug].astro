---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { readStudent } from '../../../lib/siteContent';

const slug = Astro.params.slug;
if (!slug) {
	return Astro.redirect('/admin/class');
}

let data;
let body: string;
try {
	const s = await readStudent(slug);
	data = s.data;
	body = s.body;
} catch {
	return Astro.redirect('/admin/class');
}

const padEtudes = [...data.etudes, ...Array.from({ length: 6 }, () => ({ title: '', passed: false, date: '' }))];
const title = `Ученик · ${data.displayName}`;
---

<Layout admin title={title}>
	<div class="mb-6 flex flex-wrap items-center justify-between gap-3">
		<div>
			<h1 class="font-display text-2xl font-extrabold text-ink sm:text-3xl">{data.displayName}</h1>
			<p class="mt-1 text-sm text-muted">
				Файл: <code class="rounded bg-slate-100 px-1">src/content/students/{slug}.md</code>
			</p>
		</div>
		<a
			href="/admin/class"
			class="rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50"
		>
			← К классу
		</a>
	</div>

	<form id="student-form" class="space-y-6 rounded-3xl border border-amber-200/80 bg-surface p-6 shadow-[var(--shadow-card)] sm:p-8">
		<input type="hidden" id="slug" value={slug} />
		<label class="block text-sm font-semibold">
			Slug (из имени файла)
			<input
				type="text"
				id="field-slug"
				value={data.slug}
				readonly
				class="mt-1 w-full cursor-not-allowed rounded-xl border border-slate-200 bg-slate-50 px-3 py-2 text-base text-muted"
			/>
		</label>
		<div class="grid gap-4 sm:grid-cols-2">
			<label class="block text-sm font-semibold sm:col-span-2">
				Имя на сцене
				<input
					type="text"
					id="displayName"
					value={data.displayName}
					class="mt-1 w-full rounded-xl border border-slate-200 px-3 py-2 text-base"
				/>
			</label>
			<label class="block text-sm font-semibold sm:col-span-2">
				ФИО
				<input
					type="text"
					id="fullName"
					value={data.fullName}
					class="mt-1 w-full rounded-xl border border-slate-200 px-3 py-2 text-base"
				/>
			</label>
			<label class="block text-sm font-semibold">
				День рождения
				<input
					type="text"
					id="birthday"
					value={data.birthday ?? ''}
					class="mt-1 w-full rounded-xl border border-slate-200 px-3 py-2 text-base"
				/>
			</label>
			<label class="block text-sm font-semibold">
				Порядок (число)
				<input
					type="number"
					id="order"
					value={String(data.order)}
					class="mt-1 w-full rounded-xl border border-slate-200 px-3 py-2 text-base"
				/>
			</label>
			<label class="block text-sm font-semibold">
				Псевдоним
				<input
					type="text"
					id="nickname"
					value={data.nickname ?? ''}
					class="mt-1 w-full rounded-xl border border-slate-200 px-3 py-2 text-base"
				/>
			</label>
			<label class="block text-sm font-semibold">
				Телефон
				<input type="text" id="phone" value={data.phone ?? ''} class="mt-1 w-full rounded-xl border border-slate-200 px-3 py-2 text-base" />
			</label>
			<label class="block text-sm font-semibold sm:col-span-2">
				Фото (URL)
				<input type="text" id="photo" value={data.photo ?? ''} class="mt-1 w-full rounded-xl border border-slate-200 px-3 py-2 text-base" />
			</label>
		</div>

		<div>
			<h2 class="font-display text-base font-bold text-accent">Этюды</h2>
			<p class="mt-1 text-xs text-muted">Пустые строки не сохраняются.</p>
			<div id="etude-rows" class="mt-3 space-y-3">
				{
					padEtudes.map((e) => (
						<div class="etude-row grid gap-2 rounded-xl border border-slate-100 bg-slate-50/80 p-3 sm:grid-cols-[1fr_auto_7rem] sm:items-end">
							<label class="text-xs font-semibold text-muted">
								Название
								<input
									type="text"
									class="et-title mt-1 w-full rounded-lg border border-slate-200 bg-white px-2 py-2 text-sm text-ink"
									value={e.title}
								/>
							</label>
							<label class="flex items-center gap-2 text-sm font-semibold text-ink sm:pb-2">
								<input type="checkbox" class="et-passed h-4 w-4" checked={e.passed} />
								Сдан
							</label>
							<label class="text-xs font-semibold text-muted">
								Дата
								<input
									type="text"
									class="et-date mt-1 w-full rounded-lg border border-slate-200 bg-white px-2 py-2 text-sm"
									value={e.date ?? ''}
								/>
							</label>
						</div>
					))
				}
			</div>
		</div>

		<label class="block text-sm font-semibold">
			Текст карточки (Markdown)
			<textarea id="md-body" rows="10" class="mt-1 w-full rounded-xl border border-slate-200 px-3 py-2 font-mono text-sm">
				{body}
			</textarea>
		</label>

		<div class="flex flex-wrap items-center gap-3">
			<button
				type="submit"
				class="rounded-full bg-blue-600 px-5 py-2.5 text-sm font-bold text-white shadow-md hover:bg-blue-700"
			>
				Сохранить
			</button>
			<span id="student-status" class="text-sm text-muted"></span>
		</div>
	</form>

	<script>
		const form = document.getElementById('student-form');
		const status = document.getElementById('student-status');
		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			if (!status) return;
			const slug = (document.getElementById('slug') as HTMLInputElement)?.value;
			if (!slug) return;
			const etudes: { title: string; passed: boolean; date?: string }[] = [];
			document.querySelectorAll('.etude-row').forEach((row) => {
				const title = (row.querySelector('.et-title') as HTMLInputElement)?.value?.trim() ?? '';
				if (!title) return;
				const passed = Boolean((row.querySelector('.et-passed') as HTMLInputElement)?.checked);
				const dateRaw = (row.querySelector('.et-date') as HTMLInputElement)?.value?.trim() ?? '';
				const o: { title: string; passed: boolean; date?: string } = { title, passed };
				if (dateRaw) o.date = dateRaw;
				etudes.push(o);
			});
			const orderRaw = Number((document.getElementById('order') as HTMLInputElement)?.value);
			const order = Number.isFinite(orderRaw) ? orderRaw : 0;
			const payload = {
				data: {
					slug,
					displayName: (document.getElementById('displayName') as HTMLInputElement).value,
					fullName: (document.getElementById('fullName') as HTMLInputElement).value,
					birthday: (document.getElementById('birthday') as HTMLInputElement).value || undefined,
					nickname: (document.getElementById('nickname') as HTMLInputElement).value || undefined,
					phone: (document.getElementById('phone') as HTMLInputElement).value || undefined,
					photo: (document.getElementById('photo') as HTMLInputElement).value || undefined,
					order,
					etudes,
				},
				body: (document.getElementById('md-body') as HTMLTextAreaElement).value,
			};
			status.textContent = 'Сохраняю…';
			const res = await fetch(`/api/admin/student/${encodeURIComponent(slug)}`, {
				method: 'PUT',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(payload),
			});
			const j = await res.json().catch(() => ({}));
			if (!res.ok) {
				status.textContent = j.error ? JSON.stringify(j.error) : 'Ошибка';
				return;
			}
			status.textContent = 'Сохранено.';
		});
	</script>
</Layout>
