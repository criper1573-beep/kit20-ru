---
export const prerender = false;
import Layout from '../../../layouts/Layout.astro';
import { readStudent } from '../../../lib/siteContent';
import { hasValidAdminSession } from '../../../lib/adminApiAuth';

const slug = Astro.params.slug;
if (!slug) {
	return Astro.redirect('/admin/class');
}

if (!hasValidAdminSession(Astro.cookies)) {
	const nextUrl = Astro.url.pathname + Astro.url.search;
	return Astro.redirect(`/admin/login?next=${encodeURIComponent(nextUrl)}`);
}

let data;
let body: string;
try {
	const s = await readStudent(slug);
	data = s.data;
	body = s.body;
} catch {
	return Astro.redirect('/admin/class');
}

const padEtudes = [...data.etudes, ...Array.from({ length: 6 }, () => ({ title: '', passed: false, date: '' }))];
const title = `Ученик · ${data.displayName}`;
---

<Layout admin title={title}>
	<div class="mb-8 flex flex-wrap items-center justify-between gap-4 border-b-[3px] border-ink pb-4">
		<div>
			<h1 class="font-display text-3xl font-normal tracking-widest text-ink sm:text-4xl uppercase">{data.displayName}</h1>
			<p class="mt-2 font-sans text-sm uppercase tracking-wider text-muted">
				Файл: <code class="border-[2px] border-ink bg-muted-surface px-1.5 py-0.5 text-ink">src/content/students/{slug}.md</code>
			</p>
		</div>
		<a
			href="/admin/class"
			class="border-[3px] border-ink bg-surface px-4 py-2 font-sans text-sm font-bold uppercase tracking-widest text-ink shadow-[var(--shadow-card)] hover:bg-accent hover:text-canvas active-shift transition-colors"
		>
			← К классу
		</a>
	</div>

	<form id="student-form" class="space-y-8 border-[3px] border-ink bg-surface p-6 shadow-[var(--shadow-card)] sm:p-8">
		<input type="hidden" id="slug" value={slug} />
		<label class="block font-sans text-sm font-bold uppercase tracking-wider">
			Slug (из имени файла)
			<input
				type="text"
				id="field-slug"
				value={data.slug}
				readonly
				class="mt-2 w-full cursor-not-allowed border-[3px] border-ink bg-muted-surface px-3 py-2 font-sans text-base text-muted shadow-[var(--shadow-card)] focus:outline-none"
			/>
		</label>
		<div class="grid gap-6 sm:grid-cols-2">
			<label class="block font-sans text-sm font-bold uppercase tracking-wider sm:col-span-2">
				Имя на сцене
				<input
					type="text"
					id="displayName"
					value={data.displayName}
					class="mt-2 w-full border-[3px] border-ink bg-surface px-3 py-2 font-sans text-base shadow-[var(--shadow-card)] focus:outline-none focus:ring-2 focus:ring-accent"
				/>
			</label>
			<label class="block font-sans text-sm font-bold uppercase tracking-wider sm:col-span-2">
				ФИО
				<input
					type="text"
					id="fullName"
					value={data.fullName}
					class="mt-2 w-full border-[3px] border-ink bg-surface px-3 py-2 font-sans text-base shadow-[var(--shadow-card)] focus:outline-none focus:ring-2 focus:ring-accent"
				/>
			</label>
			<label class="block font-sans text-sm font-bold uppercase tracking-wider">
				День рождения
				<input
					type="text"
					id="birthday"
					value={data.birthday ?? ''}
					class="mt-2 w-full border-[3px] border-ink bg-surface px-3 py-2 font-sans text-base shadow-[var(--shadow-card)] focus:outline-none focus:ring-2 focus:ring-accent"
				/>
			</label>
			<label class="block font-sans text-sm font-bold uppercase tracking-wider">
				Порядок (число)
				<input
					type="number"
					id="order"
					value={String(data.order)}
					class="mt-2 w-full border-[3px] border-ink bg-surface px-3 py-2 font-sans text-base shadow-[var(--shadow-card)] focus:outline-none focus:ring-2 focus:ring-accent"
				/>
			</label>
			<label class="block font-sans text-sm font-bold uppercase tracking-wider">
				Псевдоним
				<input
					type="text"
					id="nickname"
					value={data.nickname ?? ''}
					class="mt-2 w-full border-[3px] border-ink bg-surface px-3 py-2 font-sans text-base shadow-[var(--shadow-card)] focus:outline-none focus:ring-2 focus:ring-accent"
				/>
			</label>
			<label class="block font-sans text-sm font-bold uppercase tracking-wider">
				Телефон
				<input type="text" id="phone" value={data.phone ?? ''} class="mt-2 w-full border-[3px] border-ink bg-surface px-3 py-2 font-sans text-base shadow-[var(--shadow-card)] focus:outline-none focus:ring-2 focus:ring-accent" />
			</label>
			
			<div class="block font-sans text-sm font-bold uppercase tracking-wider sm:col-span-2">
				Фото ученика
				<div class="mt-2 flex items-center gap-4">
					<input type="hidden" id="photo" value={data.photo ?? ''} />
					<img id="photo-preview" src={data.photo ?? ''} class="h-24 w-20 border-[3px] border-ink object-cover shadow-[var(--shadow-card)]" style={data.photo ? '' : 'display:none;'} />
					<label class="cursor-pointer border-[3px] border-ink bg-surface px-4 py-2 font-bold uppercase tracking-widest text-ink shadow-[var(--shadow-card)] hover:bg-accent hover:text-canvas active-shift transition-colors">
						Загрузить фото
						<input type="file" id="photo-upload" accept="image/*" class="hidden" />
					</label>
					<span id="upload-status" class="text-xs text-muted"></span>
				</div>
			</div>
		</div>

		<div class="border-t-[3px] border-ink pt-6">
			<div class="flex flex-wrap items-center justify-between gap-4">
				<h2 class="font-display text-2xl font-normal tracking-widest text-accent uppercase">Этюды</h2>
				<button type="button" id="add-etude-btn" class="type-cta border-[2px] border-ink bg-surface px-3 py-1.5 text-xs text-ink shadow-[var(--shadow-card)] hover:bg-accent hover:text-canvas active-shift transition-colors">
					+ Добавить этюд
				</button>
			</div>
			<p class="mt-2 font-sans text-xs uppercase tracking-wider text-muted">Пустые строки не сохраняются. Для удаления очистите название или нажмите крестик.</p>
			<div id="etude-rows" class="mt-4 space-y-4">
				{
					padEtudes.map((e) => (
						<div class="etude-row relative grid gap-3 border-[3px] border-ink bg-muted-surface p-4 shadow-[var(--shadow-card)] sm:grid-cols-[1fr_auto_8rem] sm:items-end pr-10">
							<button type="button" class="remove-etude-btn absolute right-2 top-2 flex h-6 w-6 items-center justify-center text-muted hover:text-accent" title="Удалить этюд">✕</button>
							<label class="font-sans text-xs uppercase tracking-wider text-ink">
								Название
								<input
									type="text"
									class="et-title mt-2 w-full border-[2px] border-ink bg-surface px-3 py-2 font-sans text-sm text-ink focus:outline-none focus:ring-2 focus:ring-accent"
									value={e.title}
								/>
							</label>
							<label class="flex cursor-pointer items-center gap-3 font-sans text-sm uppercase tracking-wider text-ink sm:pb-2">
								<input type="checkbox" class="et-passed h-5 w-5 border-[2px] border-ink accent-accent" checked={e.passed} />
								Сдан
							</label>
							<label class="font-sans text-xs uppercase tracking-wider text-ink">
								Дата
								<input
									type="text"
									class="et-date mt-2 w-full border-[2px] border-ink bg-surface px-3 py-2 font-sans text-sm focus:outline-none focus:ring-2 focus:ring-accent"
									value={e.date ?? ''}
								/>
							</label>
						</div>
					))
				}
			</div>
		</div>

		<label class="block border-t-[3px] border-ink pt-6 font-sans text-sm font-bold uppercase tracking-wider">
			Текст карточки (Markdown)
			<textarea id="md-body" rows="10" class="mt-2 w-full border-[3px] border-ink bg-surface px-3 py-2 font-mono text-sm leading-relaxed shadow-[var(--shadow-card)] focus:outline-none focus:ring-2 focus:ring-accent">
				{body}
			</textarea>
		</label>

		<div class="flex flex-wrap items-center gap-4 pt-4">
			<button
				type="submit"
				class="border-[3px] border-ink bg-accent px-6 py-3 font-display text-xl tracking-widest text-canvas shadow-[var(--shadow-card)] hover:bg-accent-hover active-shift transition-colors"
			>
				Сохранить
			</button>
			<span id="student-status" class="font-sans text-sm font-bold uppercase text-muted"></span>
		</div>
	</form>

	<script>
		const form = document.getElementById('student-form');
		const status = document.getElementById('student-status');
		const photoUpload = document.getElementById('photo-upload') as HTMLInputElement;
		const photoInput = document.getElementById('photo') as HTMLInputElement;
		const photoPreview = document.getElementById('photo-preview') as HTMLImageElement;
		const uploadStatus = document.getElementById('upload-status');
		let autosaveTimer: number | null = null;
		let saveRequestId = 0;
		let latestSavedId = 0;

		function collectPayload() {
			const slug = (document.getElementById('slug') as HTMLInputElement)?.value;
			const etudes: { title: string; passed: boolean; date?: string }[] = [];
			document.querySelectorAll('.etude-row').forEach((row) => {
				const title = (row.querySelector('.et-title') as HTMLInputElement)?.value?.trim() ?? '';
				if (!title) return;
				const passed = Boolean((row.querySelector('.et-passed') as HTMLInputElement)?.checked);
				const dateRaw = (row.querySelector('.et-date') as HTMLInputElement)?.value?.trim() ?? '';
				const o: { title: string; passed: boolean; date?: string } = { title, passed };
				if (dateRaw) o.date = dateRaw;
				etudes.push(o);
			});
			const orderRaw = Number((document.getElementById('order') as HTMLInputElement)?.value);
			const order = Number.isFinite(orderRaw) ? orderRaw : 0;
			return {
				slug,
				payload: {
					data: {
						slug,
						displayName: (document.getElementById('displayName') as HTMLInputElement).value,
						fullName: (document.getElementById('fullName') as HTMLInputElement).value,
						birthday: (document.getElementById('birthday') as HTMLInputElement).value || undefined,
						nickname: (document.getElementById('nickname') as HTMLInputElement).value || undefined,
						phone: (document.getElementById('phone') as HTMLInputElement).value || undefined,
						photo: (document.getElementById('photo') as HTMLInputElement).value || undefined,
						order,
						etudes,
					},
					body: (document.getElementById('md-body') as HTMLTextAreaElement).value,
				},
			};
		}

		async function saveStudent(mode: 'manual' | 'auto') {
			if (!status) return false;
			const { slug, payload } = collectPayload();
			if (!slug) return false;
			const requestId = ++saveRequestId;
			status.textContent = mode === 'manual' ? 'Сохраняю…' : 'Автосохранение…';
			const res = await fetch(`/api/admin/student/${encodeURIComponent(slug)}`, {
				method: 'PUT',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(payload),
			});
			const j = await res.json().catch(() => ({}));
			if (requestId < latestSavedId) return false;
			if (!res.ok) {
				status.textContent = j.error ? JSON.stringify(j.error) : 'Ошибка';
				return false;
			}
			latestSavedId = requestId;
			status.textContent = mode === 'manual' ? 'Сохранено.' : 'Автосохранено.';
			return true;
		}

		function scheduleAutoSave() {
			if (autosaveTimer) window.clearTimeout(autosaveTimer);
			autosaveTimer = window.setTimeout(() => {
				saveStudent('auto');
			}, 700);
		}

		photoUpload?.addEventListener('change', async () => {
			const file = photoUpload.files?.[0];
			if (!file) return;
			
			if (uploadStatus) uploadStatus.textContent = 'Загрузка...';
			
			const fd = new FormData();
			fd.append('file', file);
			
			try {
				const res = await fetch('/api/admin/upload', {
					method: 'POST',
					body: fd,
				});
				const data = await res.json();
				
				if (res.ok && data.url) {
					photoInput.value = data.url;
					photoPreview.src = data.url;
					photoPreview.style.display = 'block';
					if (uploadStatus) uploadStatus.textContent = 'Загружено';
					scheduleAutoSave();
				} else {
					if (uploadStatus) uploadStatus.textContent = 'Ошибка загрузки';
				}
			} catch (e) {
				if (uploadStatus) uploadStatus.textContent = 'Ошибка загрузки';
			}
		});

		const addEtudeBtn = document.getElementById('add-etude-btn');
		const etudeRows = document.getElementById('etude-rows');

		if (etudeRows) {
			etudeRows.addEventListener('click', (e) => {
				const target = e.target as HTMLElement | null;
				const removeBtn = target?.closest('.remove-etude-btn');
				if (!removeBtn) return;
				const row = removeBtn.closest('.etude-row');
				if (row) {
					row.remove();
					scheduleAutoSave();
				}
			});
		}

		addEtudeBtn?.addEventListener('click', () => {
			if (!etudeRows) return;
			const div = document.createElement('div');
			div.className = 'etude-row relative grid gap-3 border-[3px] border-ink bg-muted-surface p-4 shadow-[var(--shadow-card)] sm:grid-cols-[1fr_auto_8rem] sm:items-end pr-10';
			div.innerHTML = `
				<button type="button" class="remove-etude-btn absolute right-2 top-2 flex h-6 w-6 items-center justify-center text-muted hover:text-accent" title="Удалить этюд">✕</button>
				<label class="font-sans text-xs uppercase tracking-wider text-ink">
					Название
					<input type="text" class="et-title mt-2 w-full border-[2px] border-ink bg-surface px-3 py-2 font-sans text-sm text-ink focus:outline-none focus:ring-2 focus:ring-accent" value="" />
				</label>
				<label class="flex cursor-pointer items-center gap-3 font-sans text-sm uppercase tracking-wider text-ink sm:pb-2">
					<input type="checkbox" class="et-passed h-5 w-5 border-[2px] border-ink accent-accent" />
					Сдан
				</label>
				<label class="font-sans text-xs uppercase tracking-wider text-ink">
					Дата
					<input type="text" class="et-date mt-2 w-full border-[2px] border-ink bg-surface px-3 py-2 font-sans text-sm focus:outline-none focus:ring-2 focus:ring-accent" value="" />
				</label>
			`;
			etudeRows.appendChild(div);
			scheduleAutoSave();
		});

		form?.querySelectorAll('input, textarea').forEach((el) => {
			el.addEventListener('input', scheduleAutoSave);
			el.addEventListener('change', scheduleAutoSave);
		});

		form?.addEventListener('submit', async (e) => {
			e.preventDefault();
			await saveStudent('manual');
		});
	</script>
</Layout>