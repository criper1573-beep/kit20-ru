---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import ClassPageOverlay from '../components/ClassPageOverlay.astro';
import StudentAvatar from '../components/StudentAvatar.astro';
import { readStudentsSorted } from '../lib/siteContent';
import { renderMarkdownToHtml } from '../lib/renderMarkdown';

const rows = await readStudentsSorted();

const blocks = rows.map((entry, i) => ({
	slug: entry.data.slug,
	data: entry.data,
	bodyHtml: renderMarkdownToHtml(entry.body),
	variant: i,
}));

const stageBlocks = blocks.map(({ slug, data, variant }) => ({
	slug,
	data: { displayName: data.displayName },
	variant,
}));
---

<Layout title="Класс" description="Карточки группы и этюды">
	<ClassPageOverlay slot="class-overlay" blocks={stageBlocks} />
	<div class="min-h-[min(88vh,52rem)] w-full" aria-hidden="true"></div>
	{
		blocks.map(({ slug, data, bodyHtml, variant }) => (
			<dialog
				id={`dlg-${slug}`}
				class="fixed left-1/2 top-1/2 z-[100] w-[min(100vw-2rem,28rem)] max-w-[calc(100vw-2rem)] -translate-x-1/2 -translate-y-1/2 overflow-hidden border-[3px] border-ink bg-surface p-0 text-ink shadow-[var(--shadow-float)]"
			>
				<div class="border-b-[3px] border-ink bg-muted-surface px-5 py-4">
					<div class="flex items-start justify-between gap-4">
						<div>
							<h2 class="font-display text-2xl font-normal text-ink sm:text-3xl uppercase tracking-wider">{data.displayName}</h2>
							{data.fullName && <p class="text-sm font-sans text-muted uppercase">{data.fullName}</p>}
						</div>
						<button
							type="button"
							class="type-cta border-[3px] border-ink bg-surface px-3 py-2 text-sm text-ink shadow-[var(--shadow-card)] hover:bg-accent hover:text-canvas active-shift transition-colors"
							data-close-dialog=""
						>
							Закрыть
						</button>
					</div>
				</div>
				<div class="max-h-[min(70vh,32rem)] overflow-y-auto px-5 py-6">
					<div class="mb-6 flex gap-5">
						<div class="h-28 w-24 shrink-0 border-[3px] border-ink bg-muted-surface overflow-hidden">
							<StudentAvatar variant={variant} displayName={data.displayName} class="h-full w-full" />
						</div>
						<dl class="grid flex-1 gap-2 text-sm font-sans">
							{data.fullName && (
								<div class="flex justify-between gap-4 border-b-2 border-ink/10 py-1.5">
									<dt class="text-muted font-bold">ФИО</dt>
									<dd class="text-right font-bold text-ink">{data.fullName}</dd>
								</div>
							)}
							{data.birthday && (
								<div class="flex justify-between gap-4 border-b-2 border-ink/10 py-1.5">
									<dt class="text-muted font-bold">ДР</dt>
									<dd class="text-right font-bold text-ink">{data.birthday}</dd>
								</div>
							)}
							{data.nickname && (
								<div class="flex justify-between gap-4 border-b-2 border-ink/10 py-1.5">
									<dt class="text-muted font-bold">НИК</dt>
									<dd class="text-right font-bold text-ink">{data.nickname}</dd>
								</div>
							)}
							{data.phone && (
								<div class="flex justify-between gap-4 border-b-2 border-ink/10 py-1.5">
									<dt class="text-muted font-bold">ТЕЛ</dt>
									<dd class="text-right font-bold text-ink">{data.phone}</dd>
								</div>
							)}
						</dl>
					</div>
					{data.photo && (
						<img
							src={data.photo}
							alt=""
							class="mb-6 max-h-56 w-full border-[3px] border-ink object-cover object-top shadow-[var(--shadow-card)] grayscale hover:grayscale-0 transition-all duration-500"
							loading="lazy"
						/>
					)}
					{data.etudes.length > 0 && (
						<>
							<h3 class="mb-3 font-display text-xl font-normal tracking-widest text-accent uppercase">Этюды</h3>
							<ul class="space-y-3 font-sans">
								{data.etudes.map((e) => (
									<li class="kit-etude-card" tabindex="0">
										<div class="flex flex-wrap items-center justify-between gap-2">
											<span class="kit-etude-shift kit-etude-shift--title uppercase text-ink">{e.title}</span>
											<span
												class:list={[
													'kit-etude-shift kit-etude-shift--badge border-[2px] border-ink px-2 py-0.5 text-xs uppercase',
													e.passed ? 'bg-accent text-canvas' : 'bg-muted-surface text-ink',
												]}
											>
												{e.passed ? 'Сдан' : 'Не сдан'}
											</span>
										</div>
										{e.date && (
											<p class="kit-etude-shift kit-etude-shift--date mt-2 text-xs font-bold text-muted">{e.date}</p>
										)}
									</li>
								))}
							</ul>
						</>
					)}
					<div class="markdown-body mt-8 border-t-[3px] border-ink pt-6 text-sm" set:html={bodyHtml} />
				</div>
			</dialog>
		))
	}

	<script is:inline>
		document.querySelectorAll('[data-open-dialog]').forEach((btn) => {
			btn.addEventListener('click', () => {
				const id = btn.getAttribute('data-open-dialog');
				if (id?.startsWith('dlg-')) {
					const slug = id.slice(4);
					document.querySelectorAll(`[data-stage-slug="${slug}"]`).forEach((el) => {
						el.classList.add('class-stage-figure-pulse');
						window.setTimeout(() => el.classList.remove('class-stage-figure-pulse'), 780);
					});
				}
				const dlg = id ? document.getElementById(id) : null;
				if (dlg instanceof HTMLDialogElement) dlg.showModal();
			});
		});
		document.querySelectorAll('[data-close-dialog]').forEach((btn) => {
			btn.addEventListener('click', () => {
				const dlg = btn.closest('dialog');
				dlg?.close();
			});
		});
		document.querySelectorAll('dialog').forEach((dlg) => {
			dlg.addEventListener('click', (e) => {
				if (e.target === dlg) dlg.close();
			});
		});
	</script>
</Layout>
