---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { readHome } from '../lib/siteContent';
import { renderMarkdownToHtml } from '../lib/renderMarkdown';
import type { HomeFrontmatter } from '../lib/schemas';

const { data, body } = await readHome();
const bodyHtml = renderMarkdownToHtml(body);
const title = data.title;

const defaultSemesters = [
	{ label: '2026/27 路 褋械屑械褋褌褉 1', progress: 20, color: 'accent' as const },
	{ label: '2026/27 路 褋械屑械褋褌褉 2', progress: 10, color: 'ink' as const },
	{ label: '2027/28 路 褋械屑械褋褌褉 1', progress: 10, color: 'ink' as const },
	{ label: '2027/28 路 褋械屑械褋褌褉 2', progress: 10, color: 'ink' as const },
];
const semesters = data.semesters?.length ? data.semesters : defaultSemesters;

function fontFamilyClass(f: HomeFrontmatter['titleFont']): string {
	if (f === 'sans') return 'font-sans';
	if (f === 'serif') return 'font-serif';
	return 'font-display';
}

function weightClass(w: HomeFrontmatter['titleWeight']): string {
	return w === 'bold' ? 'font-bold' : 'font-normal';
}

function progressFillClass(color: string | undefined): string {
	switch (color) {
		case 'accent':
			return 'bb-progress-fill--accent';
		case 'muted':
			return 'bb-progress-fill--muted';
		case 'mono':
			return 'bb-progress-fill--mono';
		default:
			return '';
	}
}

const titleFont = data.titleFont ?? 'display';
const titleWeight = data.titleWeight ?? 'normal';
const titleItalic = data.titleItalic ?? false;
const subtitleFont = data.subtitleFont ?? 'sans';
const subtitleWeight = data.subtitleWeight ?? 'normal';
const subtitleItalic = data.subtitleItalic ?? false;
---

<Layout title={title}>
	<section
		class="relative mb-12 overflow-hidden border-[3px] border-ink bg-surface p-8 shadow-[var(--shadow-card)] sm:p-12"
	>
		<h1
			class:list={[
				'text-balance text-5xl uppercase leading-[0.95] tracking-[-0.02em] text-ink sm:text-6xl lg:text-7xl',
				fontFamilyClass(titleFont),
				weightClass(titleWeight),
				titleItalic ? 'italic' : 'not-italic',
			]}
		>
			<span id="home-hero-title" class="inline-block tracking-[0.08em]">
				{data.title}
			</span>
		</h1>
		{
			data.subtitle && (
				<p
					class:list={[
						'mt-4 max-w-2xl text-2xl leading-tight text-accent sm:text-3xl',
						fontFamilyClass(subtitleFont),
						weightClass(subtitleWeight),
						subtitleItalic ? 'italic' : 'not-italic',
						subtitleFont === 'display' ? 'type-cta uppercase tracking-[0.18em]' : '',
					]}
				>
					{data.subtitle}
				</p>
			)
		}

		{
			data.photo && (
				<div class="mt-8 overflow-hidden border-[3px] border-ink bg-muted-surface shadow-[var(--shadow-card)]">
					<img
						src={data.photo}
						alt="肖芯褌芯 谐褉褍锌锌褘"
						class="max-h-[500px] w-full object-cover grayscale transition-all duration-500 hover:grayscale-0"
					/>
				</div>
			)
		}

		<div class="mt-10 max-w-3xl border-t-[3px] border-ink pt-8">
			<h2 class="mb-4 font-display text-lg uppercase tracking-[0.18em] text-ink font-normal">校褔械斜薪褘械 褋械屑械褋褌褉褘 (2 谐芯写邪)</h2>
			<div class="flex flex-col gap-5">
				{
					semesters.map((s) => (
						<div>
							<div class="bb-progress-label text-ink/85">{s.label}</div>
							<div class="bb-progress-bar">
								<div
									class:list={['bb-progress-fill h-full', progressFillClass(s.color)]}
									style={`width: ${s.progress}%`}
								/>
							</div>
						</div>
					))
				}
			</div>
		</div>

		{
			bodyHtml.trim() && (
				<div class="markdown-body mt-10 max-w-3xl border-t-[3px] border-ink pt-8" set:html={bodyHtml} />
			)
		}
	</section>
</Layout>

<script is:inline define:vars={{ homeTitle: data.title }}>
	(function () {
		const CHARS =
			'袗袘袙袚袛袝袞袟袠袣袥袦袧袨袩袪小孝校肖啸笑效楔些蝎鞋协挟携abcdefghijklmnopqrstuvwxyz0123456789@#$%&';
		const el = document.getElementById('home-hero-title');
		if (!el) return;
		const original = homeTitle;
		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		function attachGlitch() {
			el.setAttribute('data-text', original);
			el.classList.add('glitch-title');
		}

		if (reduced) {
			el.textContent = original;
			return;
		}

		let iter = 0;
		const id = window.setInterval(() => {
			el.textContent = original
				.split('')
				.map((c, i) => {
					if (c === ' ') return ' ';
					if (i < Math.floor(iter)) return original[i];
					return CHARS[Math.floor(Math.random() * CHARS.length)];
				})
				.join('');
			iter += 0.45;
			if (iter >= original.length + 2) {
				window.clearInterval(id);
				el.textContent = original;
				attachGlitch();
			}
		}, 32);
	})();
</script>
