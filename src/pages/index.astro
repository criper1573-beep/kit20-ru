---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const homeList = await getCollection('home');
const home = homeList[0];
let Content: Awaited<ReturnType<typeof render>>['Content'] | null = null;
if (home) {
	const r = await render(home);
	Content = r.Content;
}
const title = home?.data.title ?? 'Группа театра и кино';

const attList = await getCollection('attendance');
const allLessons = attList[0]?.data.lessons ?? [];
const today = new Date().toISOString().slice(0, 10);
const upcomingLessons = [...allLessons]
	.filter((l) => l.date >= today)
	.sort((a, b) => a.date.localeCompare(b.date))
	.slice(0, 12);
---

<Layout title={title}>
	<section
		class="relative overflow-hidden rounded-3xl border border-slate-200/90 bg-surface p-8 shadow-[var(--shadow-card)] sm:p-11"
	>
		<div
			class="pointer-events-none absolute -right-16 -top-16 h-56 w-56 rounded-full bg-blue-400/15 blur-3xl"
			aria-hidden="true"
		>
		</div>
		<h1 class="font-display text-balance text-3xl font-extrabold tracking-tight text-ink sm:text-4xl lg:text-5xl">
			{home?.data.title ?? 'Группа'}
		</h1>
		{
			home?.data.subtitle && (
				<p class="mt-3 max-w-2xl text-lg font-medium text-accent">{home.data.subtitle}</p>
			)
		}
		{
			Content && (
				<div class="markdown-body mt-8 max-w-3xl">
					<Content />
				</div>
			)
		}
	</section>

	{
		upcomingLessons.length > 0 && (
			<section class="mt-10 sm:mt-12">
				<h2 class="font-display text-2xl font-extrabold tracking-tight text-ink sm:text-3xl">Ближайшие занятия</h2>
				<p class="mt-2 max-w-2xl text-sm text-muted">
					Даты из графика посещаемости. Массово на месяц:{' '}
					<code class="rounded bg-slate-100 px-1.5 py-0.5 font-mono text-xs text-ink">
						npm run schedule:month -- 2026 5
					</code>{' '}
					(пн, ср, сб).
				</p>
				<ul class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
					{upcomingLessons.map((lesson) => (
						<li class="rounded-2xl border border-slate-200/90 bg-surface px-4 py-3 shadow-[var(--shadow-card)]">
							<p class="font-display text-sm font-bold text-accent">{lesson.date}</p>
							<p class="mt-1 text-sm font-semibold text-ink">{lesson.label?.trim() ? lesson.label : 'Тема уточняется'}</p>
						</li>
					))}
				</ul>
			</section>
		)
	}
</Layout>
