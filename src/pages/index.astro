---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { readHome } from '../lib/siteContent';
import { renderMarkdownToHtml } from '../lib/renderMarkdown';

const { data, body } = await readHome();
const bodyHtml = renderMarkdownToHtml(body);
const title = data.title;

const defaultSemesters = [
	{ label: '2026/27 · семестр 1', progress: 20 },
	{ label: '2026/27 · семестр 2', progress: 10 },
	{ label: '2027/28 · семестр 1', progress: 10 },
	{ label: '2027/28 · семестр 2', progress: 10 },
];
const semesters = data.semesters?.length ? data.semesters : defaultSemesters;
---

<Layout title={title}>
	<section
		class="relative mb-12 overflow-hidden border-[3px] border-ink bg-surface p-8 shadow-[var(--shadow-card)] sm:p-12"
	>
		<h1
			class="font-display text-balance text-5xl uppercase leading-[0.95] tracking-[-0.02em] text-ink sm:text-6xl lg:text-7xl"
		>
			<span id="home-hero-title" class="inline-block tracking-[0.08em]">
				{data.title}
			</span>
		</h1>
		{
			data.subtitle && (
				<p class="type-cta mt-4 max-w-2xl text-2xl leading-tight text-accent sm:text-3xl">{data.subtitle}</p>
			)
		}

		{
			data.photo && (
				<div class="mt-8 overflow-hidden border-[3px] border-ink bg-muted-surface shadow-[var(--shadow-card)]">
					<img
						src={data.photo}
						alt="Фото группы"
						class="max-h-[500px] w-full object-cover grayscale transition-all duration-500 hover:grayscale-0"
					/>
				</div>
			)
		}

		<div class="mt-10 max-w-3xl border-t-[3px] border-ink pt-8">
			<h2 class="mb-4 font-display text-lg uppercase tracking-[0.18em] text-ink font-normal">Учебные семестры (2 года)</h2>
			<div class="flex flex-col gap-5">
				{
					semesters.map((s, i) => (
						<div>
							<div class="bb-progress-label text-ink/85">{s.label}</div>
							<div class="bb-progress-bar">
								<div
									class:list={['bb-progress-fill h-full', i % 2 === 1 ? 'bb-progress-fill--accent' : '']}
									style={`width: ${s.progress}%`}
								/>
							</div>
						</div>
					))
				}
			</div>
		</div>

		{
			bodyHtml.trim() && (
				<div class="markdown-body mt-10 max-w-3xl border-t-[3px] border-ink pt-8" set:html={bodyHtml} />
			)
		}
	</section>
</Layout>

<script is:inline define:vars={{ homeTitle: data.title }}>
	(function () {
		const CHARS =
			'АБВГДЕЖЗИКЛМНОПРСТУФХЦЧШЩЫЬЭЮЯabcdefghijklmnopqrstuvwxyz0123456789@#$%&';
		const el = document.getElementById('home-hero-title');
		if (!el) return;
		const original = homeTitle;
		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		function attachGlitch() {
			el.setAttribute('data-text', original);
			el.classList.add('glitch-title');
		}

		if (reduced) {
			el.textContent = original;
			return;
		}

		let iter = 0;
		const id = window.setInterval(() => {
			el.textContent = original
				.split('')
				.map((c, i) => {
					if (c === ' ') return ' ';
					if (i < Math.floor(iter)) return original[i];
					return CHARS[Math.floor(Math.random() * CHARS.length)];
				})
				.join('');
			iter += 0.45;
			if (iter >= original.length + 2) {
				window.clearInterval(id);
				el.textContent = original;
				attachGlitch();
			}
		}, 32);
	})();
</script>
