---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

const homeList = await getCollection('home');
const home = homeList[0];
let Content: Awaited<ReturnType<typeof render>>['Content'] | null = null;
if (home) {
	const r = await render(home);
	Content = r.Content;
}
const title = home?.data.title ?? 'Группа театра и кино';
---

<Layout title={title}>
	<section
		class="relative overflow-hidden rounded-3xl border border-slate-200/90 bg-surface p-8 shadow-[var(--shadow-card)] sm:p-11"
	>
		<div
			class="pointer-events-none absolute -right-16 -top-16 h-56 w-56 rounded-full bg-blue-400/15 blur-3xl"
			aria-hidden="true"
		>
		</div>
		<h1 class="font-display text-balance text-3xl font-extrabold tracking-tight text-ink sm:text-4xl lg:text-5xl">
			{home?.data.title ?? 'Группа'}
		</h1>
		{
			home?.data.subtitle && (
				<p class="mt-3 max-w-2xl text-lg font-medium text-accent">{home.data.subtitle}</p>
			)
		}
		{
			Content && (
				<div class="markdown-body mt-8 max-w-3xl">
					<Content />
				</div>
			)
		}
	</section>
</Layout>
