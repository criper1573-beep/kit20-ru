---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import { readHome } from '../lib/siteContent';
import { renderMarkdownToHtml } from '../lib/renderMarkdown';

const { data, body } = await readHome();
const bodyHtml = renderMarkdownToHtml(body);
const title = data.title;
---

<Layout title={title}>
	<section
		class="relative overflow-hidden rounded-3xl border border-slate-200/90 bg-surface p-8 shadow-[var(--shadow-card)] sm:p-11"
	>
		<div
			class="pointer-events-none absolute -right-16 -top-16 h-56 w-56 rounded-full bg-blue-400/15 blur-3xl"
			aria-hidden="true"
		>
		</div>
		<h1 class="font-display text-balance text-3xl font-extrabold tracking-tight text-ink sm:text-4xl lg:text-5xl">
			{data.title}
		</h1>
		{
			data.subtitle && (
				<p class="mt-3 max-w-2xl text-lg font-medium text-accent">{data.subtitle}</p>
			)
		}
		{
			bodyHtml.trim() && (
				<div class="markdown-body mt-8 max-w-3xl" set:html={bodyHtml} />
			)
		}
	</section>
</Layout>
