---
---

<section
	class="footer-tower-game relative overflow-hidden border-[3px] border-ink bg-surface shadow-[var(--shadow-card)]"
	aria-label="Мини-игра «Помоги Илону долететь на Марс»"
>
	<div class="pointer-events-none absolute inset-x-0 top-0 h-1 bg-accent" aria-hidden="true"></div>

	<div class="flex items-start justify-between gap-3 px-3 pt-3 sm:px-4 sm:pt-4">
		<div class="min-w-0 flex-1">
			<h3 class="font-display text-base uppercase leading-tight tracking-[0.12em] text-ink sm:text-lg sm:tracking-[0.16em]">
				Помоги Илону долететь на Марс
			</h3>
			<p class="mt-0.5 font-mono text-[9px] uppercase tracking-[0.14em] text-muted sm:text-[10px]">
				1 кирпич = 1 м · идеально = 2 м
			</p>
		</div>
		<button
			id="footer-tower-open-rating-top"
			type="button"
			class="shrink-0 border-[2px] border-ink bg-canvas px-2 py-1 font-mono text-[9px] uppercase tracking-[0.2em] text-accent shadow-[var(--shadow-card)] transition-colors hover:border-accent hover:text-accent-hover sm:text-[10px]"
		>
			Рейтинг
		</button>
	</div>

	<div class="mx-3 mt-2 sm:mx-4">
		<div class="bb-progress-label text-ink/85">
			<span id="footer-tower-mission-total">9 007 030</span> / 10 000 000 м
		</div>
		<div class="bb-progress-bar mt-1">
			<div id="footer-tower-mission-fill" class="bb-progress-fill bb-progress-fill--accent h-full" style="width: 90.07%"></div>
		</div>
		<p id="footer-tower-mission-sub" class="mt-1.5 font-mono text-[9px] leading-relaxed tracking-[0.1em] text-muted sm:text-[10px]">
			SpaceX: 9 000 000 м · Люди: 7 030 м · Осталось: 992 970 м
		</p>
	</div>

	<div
		class="footer-tower-game__frame mx-3 mt-3 border-[3px] border-ink bg-[#e4ddd4] p-1 shadow-[inset_0_2px_0_rgb(255_255_255/0.45)] sm:mx-4"
	>
		<div
			id="footer-tower-viewport"
			class="footer-tower-game__viewport relative overflow-hidden bg-[linear-gradient(180deg,#f0ebe0_0%,#e8e1d6_55%,#ddd6cb_100%)]"
		>
			<div
				class="pointer-events-none absolute inset-0 opacity-[0.35]"
				style="background-image: linear-gradient(#0a0a0a08 1px, transparent 1px), linear-gradient(90deg, #0a0a0a08 1px, transparent 1px); background-size: 14px 14px;"
				aria-hidden="true"
			></div>
			<canvas id="footer-tower-canvas" class="relative z-[1] block h-full w-full" width="300" height="420"></canvas>

			<div
				id="footer-tower-overlay-idle"
				class="absolute inset-0 z-[2] flex items-center justify-center p-3"
			>
				<div class="w-full max-w-[15rem] border-[3px] border-ink bg-surface p-4 text-center shadow-[var(--shadow-float)]">
					<p class="font-display text-xl uppercase tracking-[0.14em] text-ink">На Марс</p>
					<p class="mt-1 font-mono text-[9px] uppercase tracking-[0.14em] text-muted">Клик или пробел — бросить блок</p>
					<button
						id="footer-tower-start"
						type="button"
						class="type-cta mt-4 w-full border-[3px] border-ink bg-accent px-3 py-2.5 text-[10px] uppercase tracking-widest text-canvas shadow-[var(--shadow-card)] transition-colors hover:bg-accent-hover"
					>
						Старт
					</button>
				</div>
			</div>

			<div
				id="footer-tower-overlay-end"
				class="absolute inset-0 z-[3] hidden items-center justify-center p-3"
				aria-hidden="true"
			>
				<div
					class="pointer-events-none absolute inset-0 bg-[color-mix(in_srgb,var(--color-ink)_42%,transparent)] backdrop-blur-[1px]"
					aria-hidden="true"
				></div>
				<div class="relative z-[1] w-full max-w-[16rem] border-[3px] border-ink bg-surface p-4 shadow-[var(--shadow-float)]">
					<p id="footer-tower-end-title" class="font-display text-xl uppercase tracking-[0.14em] text-accent">Полёт на Марс</p>
					<p id="footer-tower-end-score" class="mt-2 font-mono text-[11px] leading-relaxed tracking-[0.1em] text-ink"></p>
					<p id="footer-tower-end-best" class="mt-1 font-mono text-[10px] uppercase tracking-[0.12em] text-muted"></p>
					<p id="footer-tower-end-coach" class="mt-3 font-serif text-[11px] italic leading-relaxed text-muted"></p>
					<p id="footer-tower-end-saved" class="mt-3 font-mono text-[10px] uppercase tracking-[0.12em] text-accent"></p>
					<div class="mt-4 flex flex-col gap-2">
						<label class="font-mono text-[9px] uppercase tracking-[0.16em] text-ink">
							Ваше имя <span class="normal-case tracking-normal text-muted">(необязательно)</span>
							<input
								id="footer-tower-name"
								type="text"
								maxlength="24"
								placeholder="Пусто — имя актёра"
								class="mt-1 w-full border-[3px] border-ink bg-canvas px-2 py-1.5 text-xs outline-none focus:ring-2 focus:ring-accent"
							/>
						</label>
						<button
							id="footer-tower-restart"
							type="button"
							class="type-cta w-full border-[3px] border-ink bg-accent px-2 py-2.5 text-[10px] uppercase tracking-widest text-canvas shadow-[var(--shadow-card)] transition-colors hover:bg-accent-hover"
						>
							Ещё раз
						</button>
					</div>
				</div>
			</div>
		</div>
	</div>

	<p id="footer-tower-status" class="mx-3 mb-3 mt-2 font-mono text-[10px] uppercase tracking-[0.18em] text-ink sm:mx-4 sm:mb-4 sm:text-[11px]">
		Клик или пробел — бросить блок на башню
	</p>
</section>

<dialog
	id="footer-tower-rating-dialog"
	class="fixed left-1/2 top-1/2 z-[120] w-[min(100vw-2rem,32rem)] max-w-[calc(100vw-2rem)] -translate-x-1/2 -translate-y-1/2 border-[3px] border-ink bg-surface p-0 text-ink shadow-[var(--shadow-float)]"
>
	<div class="border-b-[3px] border-ink bg-muted-surface px-4 py-3">
		<div class="flex items-center justify-between gap-3">
			<h4 class="font-display text-xl uppercase tracking-[0.15em] text-ink">Рейтинг миссии</h4>
			<button
				id="footer-tower-rating-close"
				type="button"
				class="type-cta border-[2px] border-ink bg-surface px-2 py-1 text-[10px] text-ink shadow-[var(--shadow-card)] hover:bg-muted-surface"
			>
				Закрыть
			</button>
		</div>
	</div>
	<div class="p-4">
		<div class="mb-3 flex gap-2">
			<button
				id="footer-tower-rating-tab-total"
				type="button"
				class="type-cta flex-1 border-[2px] border-ink bg-accent px-2 py-1.5 text-[10px] uppercase tracking-widest text-canvas shadow-[var(--shadow-card)]"
			>
				Общий вклад
			</button>
			<button
				id="footer-tower-rating-tab-best"
				type="button"
				class="type-cta flex-1 border-[2px] border-ink bg-surface px-2 py-1.5 text-[10px] uppercase tracking-widest text-ink shadow-[var(--shadow-card)] hover:bg-muted-surface"
			>
				Лучшая попытка
			</button>
		</div>
		<p id="footer-tower-rating-status" class="mb-3 font-mono text-[10px] uppercase tracking-[0.18em] text-muted">Загрузка…</p>
		<div class="bb-scrollbar max-h-64 overflow-auto border-[2px] border-ink">
			<table class="w-full border-collapse text-left">
				<thead>
					<tr class="bg-ink text-canvas">
						<th class="border-r-[2px] border-ink/30 px-2 py-2 font-display text-sm uppercase tracking-widest">#</th>
						<th class="border-r-[2px] border-ink/30 px-2 py-2 font-display text-sm uppercase tracking-widest">Имя</th>
						<th class="px-2 py-2 font-display text-sm uppercase tracking-widest">Метры</th>
					</tr>
				</thead>
				<tbody id="footer-tower-rating-body"></tbody>
			</table>
		</div>
	</div>
</dialog>

<style>
	.footer-tower-game__viewport {
		--tower-play-h: min(420px, calc(100dvh - 17rem));
		width: min(100%, calc(var(--tower-play-h) * 5 / 7));
		height: var(--tower-play-h);
		max-width: 300px;
		margin-left: auto;
		margin-right: auto;
	}
	@media (min-width: 640px) {
		.footer-tower-game__viewport {
			--tower-play-h: min(380px, calc(100dvh - 19rem));
		}
	}
</style>

<script is:inline>
	(() => {
		const canvas = document.getElementById('footer-tower-canvas');
		const viewport = document.getElementById('footer-tower-viewport');
		if (!(canvas instanceof HTMLCanvasElement) || !(viewport instanceof HTMLElement)) return;

		const ctx = canvas.getContext('2d');
		if (!ctx) return;

		const BASE_W = 300;
		const BASE_H = 420;
		const GROUND_Y = BASE_H - 28;
		const VIEW_TOP = 56;
		const BLOCK_H = 22;
		const BASE_BLOCK_W = 150;
		const PERFECT_PX = 5;
		const BASE_MOVE = 88;

		const statusEl = document.getElementById('footer-tower-status');
		const missionFillEl = document.getElementById('footer-tower-mission-fill');
		const missionTotalEl = document.getElementById('footer-tower-mission-total');
		const missionSubEl = document.getElementById('footer-tower-mission-sub');
		const overlayIdle = document.getElementById('footer-tower-overlay-idle');
		const overlayEnd = document.getElementById('footer-tower-overlay-end');
		const endTitleEl = document.getElementById('footer-tower-end-title');
		const endScoreEl = document.getElementById('footer-tower-end-score');
		const endBestEl = document.getElementById('footer-tower-end-best');
		const endCoachEl = document.getElementById('footer-tower-end-coach');
		const endSavedEl = document.getElementById('footer-tower-end-saved');
		const nameInput = document.getElementById('footer-tower-name');
		const startBtn = document.getElementById('footer-tower-start');
		const restartBtn = document.getElementById('footer-tower-restart');
		const openRatingTopBtn = document.getElementById('footer-tower-open-rating-top');
		const ratingDialog = document.getElementById('footer-tower-rating-dialog');
		const ratingCloseBtn = document.getElementById('footer-tower-rating-close');
		const ratingStatusEl = document.getElementById('footer-tower-rating-status');
		const ratingBodyEl = document.getElementById('footer-tower-rating-body');
		const ratingTabTotalBtn = document.getElementById('footer-tower-rating-tab-total');
		const ratingTabBestBtn = document.getElementById('footer-tower-rating-tab-best');

		/** @type {'total' | 'best'} */
		let ratingTab = 'total';
		/** @type {{ totalLeaderboard: unknown[], bestLeaderboard: unknown[] }} */
		let ratingCache = { totalLeaderboard: [], bestLeaderboard: [] };

		const palette = ['#d42b2b', '#0a0a0a', '#57534e', '#b45309', '#0369a1', '#7c3aed', '#be123c'];

		const sessionIdKey = 'kit20_tower_session_id';
		const sessionBestKey = 'kit20_tower_best';
		const sessionNameKey = 'kit20_tower_name';

		let scale = 1;
		let dpr = 1;
		let running = false;
		let raf = 0;
		let last = performance.now();

		/** @type {{ x: number, y: number, w: number, h: number, color: string }[]} */
		let stack = [];
		/** @type {{ x: number, y: number, w: number, h: number, vx: number, vy: number, color: string, phase: string } | null} */
		let active = null;
		/** @type {{ x: number, y: number, w: number, h: number, vy: number, color: string, life: number }[]} */
		let debris = [];
		let level = 0;
		let score = 0;
		let cameraY = 0;
		let flashText = '';
		let flashUntil = 0;
		let pendingNext = false;
		let missFall = false;
		/** @type {{ phase: string, elapsed: number, result: number, best: number, phrase: string } | null} */
		let launchAnim = null;
		let launchLift = 0;
		let engineGlow = 0;
		let shakeX = 0;

		const coachPhrases = [
			'Башня кренится — сделай «Стойка на одной ноге» по 30 сек на каждую.',
			'Не хватило точности. Пройди «Точка внимания» 90 секунд.',
			'Ритм сбился. Сделай «Хлопки по метроному» 120 BPM, 2 минуты.',
			'Мало концентрации. Выполни «Стоп-кадр эмоции» 8 поз.',
			'Пора укрепить центр. Сделай «Корни» — устойчивые стойки 2 минуты.',
			'Руки дрожат — «Планка с текстом» 45 секунд.',
			'Нужна собранность. Пройди «Квадрат дыхания» 4-4-4-4.',
			'Мало опоры. Выполни «Заземление стоп» 2 минуты.',
			'Сцена любит баланс. Сделай «Маятник корпуса» 20 повторов.',
			'Не дожал до вершины. Этюд «Препятствие и цель» на 2 минуты.',
		];

		function syncCanvasSize() {
			const rect = viewport.getBoundingClientRect();
			const w = Math.max(160, Math.floor(rect.width));
			const h = Math.max(200, Math.floor(rect.height));
			dpr = Math.min(window.devicePixelRatio || 1, 2.5);
			canvas.width = Math.max(1, Math.floor(w * dpr));
			canvas.height = Math.max(1, Math.floor(h * dpr));
			canvas.style.width = `${w}px`;
			canvas.style.height = `${h}px`;
			scale = w / BASE_W;
		}

		function formatMeters(value) {
			if (!Number.isFinite(value)) return '0';
			const n = Math.round(value);
			return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ' ');
		}

		function formatScore(value) {
			return formatMeters(value);
		}

		function updateMissionUI(mission) {
			if (!mission || typeof mission !== 'object') return;
			const total = Number(mission.totalBuiltM ?? 0);
			const goal = Number(mission.goalM ?? 10_000_000);
			const musk = Number(mission.muskBuiltM ?? 9_000_000);
			const people = Number(mission.playerBuiltM ?? 0);
			const remaining = Number(mission.playerRemainingM ?? 0);
			const pct = goal > 0 ? Math.min(100, (total / goal) * 100) : 0;
			if (missionFillEl) missionFillEl.style.width = `${pct}%`;
			if (missionTotalEl) missionTotalEl.textContent = formatMeters(total);
			if (missionSubEl) {
				const complete = Boolean(mission.missionComplete);
				missionSubEl.textContent = complete
					? `SpaceX: ${formatMeters(musk)} м · Люди: ${formatMeters(people)} м · Миссия выполнена!`
					: `SpaceX: ${formatMeters(musk)} м · Люди: +${formatMeters(people)} м · Осталось: ${formatMeters(remaining)} м`;
			}
		}

		async function loadMission() {
			try {
				const res = await fetch('/api/game/mission');
				const json = await res.json();
				if (res.ok && json?.mission) updateMissionUI(json.mission);
			} catch {}
		}

		function setRatingTab(next) {
			ratingTab = next;
			const activeCls =
				'type-cta flex-1 border-[2px] border-ink bg-accent px-2 py-1.5 text-[10px] uppercase tracking-widest text-canvas shadow-[var(--shadow-card)]';
			const idleCls =
				'type-cta flex-1 border-[2px] border-ink bg-surface px-2 py-1.5 text-[10px] uppercase tracking-widest text-ink shadow-[var(--shadow-card)] hover:bg-muted-surface';
			if (ratingTabTotalBtn instanceof HTMLButtonElement) ratingTabTotalBtn.className = next === 'total' ? activeCls : idleCls;
			if (ratingTabBestBtn instanceof HTMLButtonElement) ratingTabBestBtn.className = next === 'best' ? activeCls : idleCls;
			if (ratingStatusEl) {
				ratingStatusEl.textContent =
					next === 'total'
						? 'Сумма всех игр — идёт в общий прогресс миссии'
						: 'Лучший результат за одну попытку';
			}
			renderScores(next === 'total' ? ratingCache.totalLeaderboard : ratingCache.bestLeaderboard, next);
		}

		function rowMeters(row, mode) {
			if (mode === 'total') return Number(row?.totalMeters ?? row?.score ?? 0);
			return Number(row?.bestMeters ?? row?.score ?? 0);
		}

		function renderScores(scores, mode) {
			if (!(ratingBodyEl instanceof HTMLElement)) return;
			if (!scores.length) {
				ratingBodyEl.innerHTML = `
					<tr>
						<td colspan="3" class="px-2 py-4 text-center font-sans text-xs uppercase tracking-wider text-muted">
							Пока нет результатов.
						</td>
					</tr>
				`;
				return;
			}
			ratingBodyEl.innerHTML = scores
				.map((row, i) => {
					const name = String(row?.name ?? '');
					const s = rowMeters(row, mode);
					const isMusk = name === 'Илон Маск';
					const rowCls = isMusk ? 'bg-accent/10 font-bold' : '';
					return `
						<tr class="border-t-[2px] border-ink/15 ${rowCls}">
							<td class="border-r-[2px] border-ink/15 px-2 py-1.5 font-mono text-xs">${i + 1}</td>
							<td class="border-r-[2px] border-ink/15 px-2 py-1.5 font-sans text-sm">${name}</td>
							<td class="px-2 py-1.5 font-mono text-sm text-accent">${formatMeters(s)} м</td>
						</tr>
					`;
				})
				.join('');
		}

		function getSessionId() {
			try {
				const prev = localStorage.getItem(sessionIdKey);
				if (prev) return prev;
				const legacy = sessionStorage.getItem(sessionIdKey);
				if (legacy) {
					localStorage.setItem(sessionIdKey, legacy);
					return legacy;
				}
				const next = `s_${Date.now().toString(36)}_${Math.random().toString(36).slice(2, 10)}`;
				localStorage.setItem(sessionIdKey, next);
				return next;
			} catch {
				return '';
			}
		}

		function getSessionBest() {
			try {
				return Number(localStorage.getItem(sessionBestKey) ?? sessionStorage.getItem(sessionBestKey) ?? '0') || 0;
			} catch {
				return 0;
			}
		}

		function setSessionBest(value) {
			try {
				localStorage.setItem(sessionBestKey, String(value));
			} catch {
				try {
					sessionStorage.setItem(sessionBestKey, String(value));
				} catch {}
			}
		}

		async function openRatingDialog() {
			if (!(ratingDialog instanceof HTMLDialogElement)) return;
			ratingDialog.showModal();
			if (ratingStatusEl) ratingStatusEl.textContent = 'Загрузка…';
			try {
				const res = await fetch('/api/game/scores');
				const json = await res.json();
				if (!res.ok) throw new Error('load-failed');
				ratingCache = {
					totalLeaderboard: Array.isArray(json?.totalLeaderboard) ? json.totalLeaderboard : [],
					bestLeaderboard: Array.isArray(json?.bestLeaderboard) ? json.bestLeaderboard : [],
				};
				if (json?.mission) updateMissionUI(json.mission);
				setRatingTab(ratingTab);
			} catch {
				ratingCache = { totalLeaderboard: [], bestLeaderboard: [] };
				renderScores([], ratingTab);
				if (ratingStatusEl) ratingStatusEl.textContent = 'Ошибка загрузки';
			}
		}

		function towerTopY() {
			let topY = stack[stack.length - 1].y;
			if (active && active.y < topY) topY = active.y;
			return topY;
		}

		function updateCamera() {
			if (!stack.length) {
				cameraY = 0;
				return;
			}
			const baseBottom = stack[0].y + stack[0].h;
			const topY = towerTopY();
			const towerHeight = baseBottom - topY;
			const maxFit = GROUND_Y - VIEW_TOP;

			if (towerHeight <= maxFit) {
				cameraY = 0;
			} else {
				cameraY = topY - VIEW_TOP;
			}
		}

		function spawnMovingBlock() {
			const top = stack[stack.length - 1];
			const w = top.w;
			const y = top.y - BLOCK_H - 2;
			const fromLeft = level % 2 === 0;
			const speed = BASE_MOVE + level * 5;
			const x = fromLeft ? 8 : BASE_W - w - 8;
			active = {
				x,
				y,
				w,
				h: BLOCK_H,
				vx: fromLeft ? speed : -speed,
				vy: 0,
				color: palette[level % palette.length],
				phase: 'moving',
			};
			pendingNext = false;
			missFall = false;
		}

		function showIdleOverlay() {
			if (overlayIdle) {
				overlayIdle.classList.remove('hidden');
				overlayIdle.classList.add('flex');
			}
			if (overlayEnd) {
				overlayEnd.classList.add('hidden');
				overlayEnd.classList.remove('flex');
				overlayEnd.setAttribute('aria-hidden', 'true');
			}
		}

		function hideIdleOverlay() {
			if (overlayIdle) {
				overlayIdle.classList.add('hidden');
				overlayIdle.classList.remove('flex');
			}
		}

		function showGameOverOverlay(result, best, coachPhrase) {
			hideIdleOverlay();
			if (endTitleEl) endTitleEl.textContent = 'Полёт на Марс!';
			if (endScoreEl) {
				endScoreEl.textContent =
					result > 0
						? `Ваша ракета добавила ${formatMeters(result)} м к высадке на Марс`
						: 'Попробуйте ещё — каждый метр приближает миссию';
			}
			if (endBestEl) endBestEl.textContent = `Лучший за сессию · ${formatMeters(best)} м`;
			if (endCoachEl) endCoachEl.textContent = coachPhrase;
			if (endSavedEl) endSavedEl.textContent = '';
			if (overlayEnd) {
				overlayEnd.classList.remove('hidden');
				overlayEnd.classList.add('flex');
				overlayEnd.setAttribute('aria-hidden', 'false');
			}
			if (statusEl) statusEl.textContent = 'Миссия зачислена';
		}

		function hideGameOverOverlay() {
			if (overlayEnd) {
				overlayEnd.classList.add('hidden');
				overlayEnd.classList.remove('flex');
				overlayEnd.setAttribute('aria-hidden', 'true');
			}
		}

		function resetGame() {
			level = 0;
			score = 0;
			debris = [];
			active = null;
			pendingNext = false;
			missFall = false;
			launchAnim = null;
			launchLift = 0;
			engineGlow = 0;
			shakeX = 0;
			flashText = '';
			flashUntil = 0;
			cameraY = 0;
			const baseX = (BASE_W - BASE_BLOCK_W) / 2;
			stack = [{ x: baseX, y: GROUND_Y - BLOCK_H, w: BASE_BLOCK_W, h: BLOCK_H, color: '#0a0a0a' }];
			if (statusEl) statusEl.textContent = 'Клик или пробел — бросить блок';
			hideGameOverOverlay();
			spawnMovingBlock();
		}

		function showSavedInOverlay(name, runMeters, sessionTotal, sessionBest) {
			if (endSavedEl) {
				endSavedEl.textContent = `+${formatMeters(runMeters)} м за попытку · ${formatMeters(sessionTotal)} м всего за сессию · лучшая ${formatMeters(sessionBest)} м · ${name}`;
			}
		}

		async function persistRun(runMeters, customName) {
			const meters = Math.max(0, Math.round(Number(runMeters) || 0));
			const trimmed = typeof customName === 'string' ? customName.trim() : '';
			/** @type {{ runMeters: number, sessionId: string, name?: string }} */
			const body = { runMeters: meters, sessionId: getSessionId() };
			if (trimmed) body.name = trimmed;
			if (meters <= 0 && !trimmed) return null;
			try {
				const res = await fetch('/api/game/scores', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(body),
				});
				const json = await res.json();
				if (!res.ok) throw new Error('save-failed');
				if (json?.mission) updateMissionUI(json.mission);
				if (typeof json?.name === 'string' && meters > 0) {
					showSavedInOverlay(
						json.name,
						meters,
						Number(json?.sessionTotalMeters ?? meters),
						Number(json?.sessionBestMeters ?? meters),
					);
				} else if (typeof json?.name === 'string' && trimmed) {
					if (endSavedEl) endSavedEl.textContent = `В рейтинге: ${json.name}`;
				}
				if (trimmed) {
					try {
						localStorage.setItem(sessionNameKey, trimmed);
					} catch {}
				}
				if (typeof json?.name === 'string' && json.name) {
					try {
						localStorage.setItem(sessionNameKey, json.name);
					} catch {}
				}
				return json;
			} catch {
				if (endSavedEl) endSavedEl.textContent = 'Не удалось сохранить прогресс';
				return null;
			}
		}

		/** @type {Promise<unknown>} */
		let persistChain = Promise.resolve(null);

		function queuePersistRun(runMeters, customName) {
			const job = persistChain.then(
				() => persistRun(runMeters, customName),
				() => persistRun(runMeters, customName),
			);
			persistChain = job.then(
				() => null,
				() => null,
			);
			return job;
		}

		function startGame() {
			syncCanvasSize();
			resetGame();
			hideIdleOverlay();
			running = true;
			last = performance.now();
			cancelAnimationFrame(raf);
			raf = requestAnimationFrame(loop);
		}

		function beginLaunchAfterMiss() {
			const result = score;
			const prevBest = getSessionBest();
			if (result > prevBest) setSessionBest(result);
			const best = Math.max(result, prevBest);
			const phrase = coachPhrases[Math.floor(Math.random() * coachPhrases.length)];
			running = false;
			active = null;
			debris = [];
			missFall = false;
			pendingNext = false;
			launchLift = 0;
			engineGlow = 0;
			shakeX = 0;
			launchAnim = { phase: 'ignite', elapsed: 0, result, best, phrase };
			hideGameOverOverlay();
			if (statusEl) statusEl.textContent = 'Запуск двигателей…';
		}

		function completeLaunch() {
			if (!launchAnim) return;
			const { result, best, phrase } = launchAnim;
			launchAnim = null;
			launchLift = 0;
			engineGlow = 0;
			shakeX = 0;
			showGameOverOverlay(result, best, phrase);
			if (result > 0) {
				if (endSavedEl) endSavedEl.textContent = 'Сохранение…';
				const prefilled = nameInput instanceof HTMLInputElement ? nameInput.value : '';
				void queuePersistRun(result, prefilled);
			}
		}

		function dropBlock() {
			if (!running || !active || active.phase !== 'moving') return;
			active.phase = 'falling';
			active.vy = 0;
		}

		function overlapWidth(a, b) {
			const left = Math.max(a.x, b.x);
			const right = Math.min(a.x + a.w, b.x + b.w);
			return { left, right, w: right - left };
		}

		function isPerfect(cur, top, overlap) {
			if (overlap.w <= 0) return false;
			const curMid = cur.x + cur.w / 2;
			const topMid = top.x + top.w / 2;
			return Math.abs(curMid - topMid) <= PERFECT_PX && Math.abs(overlap.w - top.w) <= PERFECT_PX;
		}

		function trimAndStack() {
			if (!active) return;
			const top = stack[stack.length - 1];
			const cur = active;
			const ov = overlapWidth(cur, top);

			if (ov.w <= 0.5) {
				missFall = true;
				active.phase = 'miss';
				active.vy = 0;
				return;
			}

			if (cur.x < ov.left - 0.5) {
				debris.push({
					x: cur.x,
					y: cur.y,
					w: ov.left - cur.x,
					h: BLOCK_H,
					vy: 0,
					color: cur.color,
					life: 1,
				});
			}
			if (cur.x + cur.w > ov.right + 0.5) {
				debris.push({
					x: ov.right,
					y: cur.y,
					w: cur.x + cur.w - ov.right,
					h: BLOCK_H,
					vy: 0,
					color: cur.color,
					life: 1,
				});
			}

			const perfect = isPerfect(cur, top, ov);
			stack.push({
				x: ov.left,
				y: top.y - BLOCK_H,
				w: ov.w,
				h: BLOCK_H,
				color: cur.color,
			});
			level += 1;
			if (perfect) {
				score += 2;
				flashText = 'Идеально! +2 м';
				flashUntil = performance.now() + 900;
			} else {
				score += 1;
			}

			active = null;
			pendingNext = true;
			updateCamera();
		}

		function drawRocketEngines() {
			if (!launchAnim || engineGlow <= 0.01 || !stack.length) return;
			const base = stack[0];
			const cx = base.x + base.w / 2 + shakeX;
			const flameTop = base.y + base.h - cameraY - launchLift;
			const flameH = 12 + engineGlow * 28;
			const flameW = Math.max(base.w * 0.28, 18);
			ctx.save();
			ctx.globalAlpha = 0.5 + engineGlow * 0.4;
			ctx.fillStyle = '#ff5a1f';
			ctx.beginPath();
			ctx.moveTo(cx - flameW, flameTop);
			ctx.lineTo(cx, flameTop + flameH);
			ctx.lineTo(cx + flameW, flameTop);
			ctx.closePath();
			ctx.fill();
			ctx.fillStyle = '#ffd24a';
			ctx.beginPath();
			ctx.moveTo(cx - flameW * 0.45, flameTop);
			ctx.lineTo(cx, flameTop + flameH * 0.62);
			ctx.lineTo(cx + flameW * 0.45, flameTop);
			ctx.closePath();
			ctx.fill();
			ctx.globalAlpha = 0.25 * engineGlow;
			ctx.fillStyle = '#0a0a0a';
			for (let i = 0; i < 5; i++) {
				const px = cx + (i - 2) * 8 + Math.sin(performance.now() * 0.02 + i) * 3;
				const py = flameTop + flameH + 6 + (launchAnim.phase === 'liftoff' ? launchLift * 0.15 : 0);
				ctx.fillRect(px, py, 4, 8 + engineGlow * 10);
			}
			ctx.restore();
		}

		function drawBlock(x, y, w, h, color, opts = {}) {
			const { highlight = false, ghost = false } = opts;
			const lift = launchAnim ? launchLift : 0;
			const shake = launchAnim ? shakeX : 0;
			const by = y - cameraY - lift;
			const bx = x + shake;
			if (by + h < -20 || by > BASE_H + 20) return;

			ctx.fillStyle = ghost ? `${color}88` : color;
			ctx.fillRect(bx, by, w, h);
			ctx.strokeStyle = '#0a0a0a';
			ctx.lineWidth = highlight ? 2.5 : 2;
			ctx.strokeRect(bx + 0.5, by + 0.5, w - 1, h - 1);

			if (highlight) {
				ctx.fillStyle = 'rgba(255,255,255,0.25)';
				ctx.fillRect(bx + 2, by + 2, w - 4, 4);
			}
		}

		function draw() {
			if (running) updateCamera();
			syncCanvasSize();
			ctx.setTransform(1, 0, 0, 1, 0, 0);
			ctx.clearRect(0, 0, canvas.width, canvas.height);
			ctx.setTransform(dpr * scale, 0, 0, dpr * scale, 0, 0);
			ctx.imageSmoothingEnabled = true;

			const skyShift = launchAnim ? Math.min(launchLift * 0.08, 40) : 0;
			ctx.fillStyle = launchAnim && launchAnim.phase === 'liftoff' ? '#e8eef5' : '#f0ebe0';
			ctx.fillRect(0, 0, BASE_W, BASE_H);
			if (launchAnim && launchAnim.phase === 'liftoff') {
				ctx.fillStyle = 'rgba(255,255,255,0.35)';
				ctx.fillRect(0, 0, BASE_W, 30 - skyShift);
			}

			const groundScreen = GROUND_Y - cameraY - (launchAnim ? launchLift : 0);
			if (groundScreen < BASE_H + 4) {
				ctx.strokeStyle = '#0a0a0a18';
				ctx.lineWidth = 1;
				ctx.setLineDash([4, 5]);
				ctx.beginPath();
				ctx.moveTo(0, groundScreen + 0.5);
				ctx.lineTo(BASE_W, groundScreen + 0.5);
				ctx.stroke();
				ctx.setLineDash([]);

				ctx.strokeStyle = '#0a0a0a';
				ctx.lineWidth = 2.5;
				ctx.beginPath();
				ctx.moveTo(0, groundScreen + 1);
				ctx.lineTo(BASE_W, groundScreen + 1);
				ctx.stroke();
			}

			for (const b of stack) drawBlock(b.x, b.y, b.w, b.h, b.color);
			for (const d of debris) drawBlock(d.x, d.y, d.w, d.h, d.color, { ghost: true });
			if (active) drawBlock(active.x, active.y, active.w, active.h, active.color, { highlight: active.phase === 'moving' });
			drawRocketEngines();

			if (!launchAnim) {
				ctx.fillStyle = '#0a0a0a';
				ctx.font = '600 11px "Space Mono", ui-monospace, monospace';
				ctx.fillText(`МЕТРЫ ${formatMeters(score)}`, 10, 18);
				ctx.fillText(`ЭТАЖ ${Math.max(0, stack.length - 1)}`, BASE_W - 88, 18);
			} else if (launchAnim.phase === 'ignite') {
				ctx.fillStyle = '#d42b2b';
				ctx.font = '700 12px "Bebas Neue", "Arial Narrow", sans-serif';
				ctx.textAlign = 'center';
				ctx.fillText('ЗАЖИГАНИЕ…', BASE_W / 2, 24);
				ctx.textAlign = 'left';
			} else if (launchAnim.phase === 'liftoff') {
				ctx.fillStyle = '#0a0a0a';
				ctx.font = '700 12px "Bebas Neue", "Arial Narrow", sans-serif';
				ctx.textAlign = 'center';
				ctx.fillText('СТАРТ!', BASE_W / 2, 24);
				ctx.textAlign = 'left';
			}

			if (flashText && performance.now() < flashUntil) {
				ctx.fillStyle = '#d42b2b';
				ctx.font = '700 13px "Bebas Neue", "Arial Narrow", sans-serif';
				ctx.textAlign = 'center';
				ctx.fillText(flashText, BASE_W / 2, 36);
				ctx.textAlign = 'left';
			}
		}

		function loop(now) {
			const dt = Math.min((now - last) / 1000, 0.033);
			last = now;

			if (running) {
				if (active) {
					if (active.phase === 'moving') {
						active.x += active.vx * dt;
						if (active.x <= 4) {
							active.x = 4;
							active.vx = Math.abs(active.vx);
						}
						if (active.x + active.w >= BASE_W - 4) {
							active.x = BASE_W - 4 - active.w;
							active.vx = -Math.abs(active.vx);
						}
					} else if (active.phase === 'falling') {
						const targetY = stack[stack.length - 1].y - BLOCK_H;
						active.vy += 920 * dt;
						active.y += active.vy * dt;
						if (active.y >= targetY) {
							active.y = targetY;
							trimAndStack();
						}
					} else if (active.phase === 'miss') {
						active.vy += 680 * dt;
						active.y += active.vy * dt;
						if (active.y > BASE_H + 40) {
							active = null;
							beginLaunchAfterMiss();
						}
					}
				}

				for (let i = debris.length - 1; i >= 0; i--) {
					const d = debris[i];
					d.vy += 720 * dt;
					d.y += d.vy * dt;
					d.life -= dt * 1.2;
					if (d.y > BASE_H + 30 || d.life <= 0) debris.splice(i, 1);
				}

				if (pendingNext && debris.length === 0 && !active && !missFall) {
					spawnMovingBlock();
				}
			}

			if (launchAnim) {
				launchAnim.elapsed += dt;
				if (launchAnim.phase === 'ignite') {
					engineGlow = Math.min(1, launchAnim.elapsed / 0.5);
					shakeX = Math.sin(launchAnim.elapsed * 90) * 2.5 * engineGlow;
					if (launchAnim.elapsed >= 0.55) {
						launchAnim.phase = 'liftoff';
						launchAnim.elapsed = 0;
					}
				} else if (launchAnim.phase === 'liftoff') {
					const speed = 300 + launchAnim.elapsed * 120;
					launchLift += speed * dt;
					engineGlow = Math.max(0.15, 1 - launchAnim.elapsed * 0.55);
					shakeX = Math.sin(launchAnim.elapsed * 40) * 1.2;
					if (launchAnim.elapsed >= 1.4 || launchLift > BASE_H + 120) {
						completeLaunch();
					}
				}
			}

			draw();
			raf = requestAnimationFrame(loop);
		}

		const ro = new ResizeObserver(() => syncCanvasSize());
		ro.observe(viewport);

		canvas.addEventListener('click', () => {
			if (!running || launchAnim) return;
			dropBlock();
		});
		window.addEventListener('keydown', (e) => {
			if (e.code === 'Space') {
				e.preventDefault();
				if (!running || launchAnim) return;
				dropBlock();
			}
		});
		startBtn?.addEventListener('click', startGame);
		restartBtn?.addEventListener('click', () => {
			if (launchAnim) return;
			startGame();
		});
		openRatingTopBtn?.addEventListener('click', openRatingDialog);
		document.addEventListener('kit20-tower-open-rating', () => {
			void openRatingDialog();
		});
		ratingTabTotalBtn?.addEventListener('click', () => setRatingTab('total'));
		ratingTabBestBtn?.addEventListener('click', () => setRatingTab('best'));
		ratingCloseBtn?.addEventListener('click', () => {
			if (ratingDialog instanceof HTMLDialogElement) ratingDialog.close();
		});
		ratingDialog?.addEventListener('click', (e) => {
			if (e.target === ratingDialog && ratingDialog instanceof HTMLDialogElement) ratingDialog.close();
		});

		let nameSaveTimer = 0;
		nameInput?.addEventListener('input', () => {
			window.clearTimeout(nameSaveTimer);
			nameSaveTimer = window.setTimeout(() => {
				if (!(nameInput instanceof HTMLInputElement)) return;
				const v = nameInput.value.trim();
				if (!v) return;
				void queuePersistRun(0, v);
			}, 500);
		});
		nameInput?.addEventListener('keydown', (e) => {
			if (e.key !== 'Enter') return;
			e.preventDefault();
			if (!(nameInput instanceof HTMLInputElement)) return;
			const v = nameInput.value.trim();
			if (v) void queuePersistRun(0, v);
		});

		void loadMission();

		if (nameInput instanceof HTMLInputElement) {
			try {
				const prevName = localStorage.getItem(sessionNameKey) ?? sessionStorage.getItem(sessionNameKey);
				if (prevName) nameInput.value = prevName;
			} catch {}
		}

		syncCanvasSize();
		resetGame();
		running = false;
		active = null;
		showIdleOverlay();
		draw();
		raf = requestAnimationFrame(loop);
	})();
</script>
