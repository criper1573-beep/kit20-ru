---
/** Верх = t1 под хедером, низ = t2 (#ticker-section бренд-бука) */
export type TickerBand = 'top' | 'bottom';

interface Props {
	band: TickerBand;
	/** Текст полосы из админки; пусто — строка по умолчанию */
	text?: string;
}

const { band, text = '' } = Astro.props;
const isTop = band === 'top';

const DEFAULT_TOP =
	'ГРУППА КИТ◆ТЕАТР◆КИНО◆ПАРТ АКАДЕМИЯ◆АКТЁРЫ◆';
const DEFAULT_BOTTOM = 'РОЛЬ ✦ СЦЕНА ✦ ПРАВДА ✦ ПРИСУТСТВИЕ ✦ МАСТЕРСТВО ✦ РЕПЕТИЦИЯ ✦ ';

const raw = text.trim();
const line = raw || (isTop ? DEFAULT_TOP : DEFAULT_BOTTOM);
---

{
	isTop ? (
		<div class="bb-ticker bb-ticker--top pointer-events-none" aria-hidden="true">
			<div class="bb-ticker-view">
				<div class:list={['bb-ticker-track', 'bb-ticker-track--t1']}>
					<span class="bb-ticker-half">{line}</span>
					<span class="bb-ticker-half">{line}</span>
				</div>
			</div>
		</div>
	) : (
		<div class="bb-ticker bb-ticker--bottom pointer-events-none" aria-hidden="true">
			<div class="bb-ticker-view">
				<div class:list={['bb-ticker-track', 'bb-ticker-track--t2']}>
					<span class="bb-ticker-half">{line}</span>
					<span class="bb-ticker-half">{line}</span>
				</div>
			</div>
		</div>
	)
}
