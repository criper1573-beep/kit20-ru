---
import StudentAvatar from './StudentAvatar.astro';
import { buildClassStageWalkerCss, buildClassStageWalkerMobileCss } from '../lib/classStageWalkCss';

export interface StageBlock {
	slug: string;
	data: { displayName: string };
	variant: number;
}

interface Props {
	blocks: StageBlock[];
}

const { blocks } = Astro.props;
const roamCss = buildClassStageWalkerCss();
const roamMobileCss = buildClassStageWalkerMobileCss();

/** Реплики «Ромео и Джульетта» — полный круг ~60 с */
const SPEECH_CYCLE_MS = 60_000;
const speechLines = [
	'Что светит в том окошке? Восток… и Джульетта — солнце.',
	'О Ромео, Ромео! Забудь отца — я стану твоей.',
	'Ужели ты Ромео? И знал ли ты запретный дом?',
	'Любовь впервые шепнула мне, когда я услышала речь твою.',
	'Как ни зовут меня — сердце узнает твой голос.',
	'Поклянись любовью — с любви слетает клятва.',
	'Не клянись ни в чём: любовь сама себе обет.',
	'Что за шум? Проклята рука, что пролила кровь!',
	'Один день наших вражд — и горе родам нашим!',
	'Прощай… ты останешься в сердце, виновник моего несчастья.',
	'Нож любви хочу занести на имя, что мне мерещится.',
	'Ночь прошла — смотри, как роса с уст твоих…',
	'Уйти? Нет, погибну здесь, где ты впервые обнял меня.',
	'Два дома, равные в чести… где заря смешает их в пепел.',
	'Тише! стража — укройся в сумраке сада.',
	'Окно открыто — лестница луны к нам склонилась.',
	'Не говори «навсегда» — скажи «сегодня», и этого достаточно.',
	'Шаги… это смерть иль мир идёт ко мне?',
	'Пусть имя твоё станет молитвой, которую шепчет ночь.',
	'Снова зовёт занавес — и снова мы встретимся в пьесе…',
];

const anchors: [number, number][] = [
	[11, 52],
	[24, 38],
	[36, 58],
	[48, 34],
	[58, 52],
	[70, 40],
	[84, 54],
	[18, 68],
	[32, 46],
	[52, 66],
	[64, 36],
	[76, 50],
	[90, 42],
	[14, 44],
	[42, 56],
	[92, 58],
];
---

<div
	class="class-stage-root relative overflow-x-hidden overflow-y-visible rounded-3xl border border-slate-200/80 bg-white shadow-[var(--shadow-card)]"
	data-class-stage=""
>
	<div
		class="relative min-h-[min(42vw,220px)] overflow-hidden rounded-t-3xl md:min-h-[440px] md:rounded-3xl"
	>
		<div class="pointer-events-none absolute inset-0 text-slate-200" aria-hidden="true">
			<svg class="h-full w-full" viewBox="0 0 800 420" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
				<defs>
					<linearGradient id="class-stage-floor" x1="0%" y1="0%" x2="0%" y2="100%">
						<stop offset="0%" stop-color="#f1f5f9" />
						<stop offset="100%" stop-color="#e2e8f0" />
					</linearGradient>
					<linearGradient id="class-stage-arch" x1="0%" y1="0%" x2="0%" y2="100%">
						<stop offset="0%" stop-color="#dbeafe" />
						<stop offset="100%" stop-color="#eff6ff" />
					</linearGradient>
				</defs>
				<rect width="800" height="420" fill="#fafafa" />
				<path d="M0 280 L800 280 L800 420 L0 420 Z" fill="url(#class-stage-floor)" />
				<path
					d="M120 280 Q400 120 680 280"
					fill="none"
					stroke="#cbd5e1"
					stroke-width="3"
					stroke-linecap="round"
					opacity="0.85"
				/>
				<path
					d="M140 278 Q400 100 660 278 L640 278 Q400 130 160 278 Z"
					fill="url(#class-stage-arch)"
					stroke="#94a3b8"
					stroke-width="2"
					opacity="0.95"
				/>
				<line x1="60" y1="295" x2="740" y2="295" stroke="#cbd5e1" stroke-width="1.5" stroke-dasharray="8 10" opacity="0.7" />
			</svg>
		</div>

		<div class="relative z-10 mx-auto w-full max-w-5xl px-2 py-2 sm:px-4 md:py-6">
			<p class="mb-1 text-center text-[11px] font-semibold uppercase tracking-[0.2em] text-slate-500 sm:text-xs md:mb-2">
				сцена · репетиция
			</p>

			<!-- Мобильная сцена -->
			<div
				class="relative mx-auto mb-1 block aspect-[10/6] w-full max-w-4xl sm:aspect-[16/9] md:mb-2 md:hidden"
			>
				{
					blocks.map((b, i) => {
						const [lx, ty] = anchors[i] ?? [50, 50];
						return (
							<button
								type="button"
								data-open-dialog={`dlg-${b.slug}`}
								data-stage-slug={b.slug}
								data-stage-roam="mobile"
								class:list={[
									'class-stage-walker-m absolute z-20 flex w-14 flex-col items-center rounded-2xl border border-transparent bg-transparent p-0.5 shadow-none transition active:bg-slate-900/[0.05] focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 [transform-style:flat]',
									`class-stage-walker-m-${i}`,
								]}
								style={`left:${lx}%; top:${ty}%;`}
							>
								<div
									class="class-stage-bubble pointer-events-none absolute bottom-[calc(100%-2px)] left-0 right-0 z-[35] flex justify-center opacity-0 transition-opacity duration-500 ease-out"
									data-stage-bubble=""
									aria-hidden="true"
								>
									<div
										class="class-stage-bubble-panel class-stage-bubble-panel--compact relative max-w-[min(9rem,calc(100vw-4rem))] rounded-lg border border-slate-200/90 bg-white px-1.5 py-1 text-center text-[8px] font-medium leading-tight text-slate-800 shadow-md"
									>
										<span data-stage-bubble-text=""></span>
									</div>
								</div>
								<div class="h-10 w-full">
									<StudentAvatar variant={b.variant} displayName={b.data.displayName} class="h-full w-full" />
								</div>
							</button>
						);
					})
				}
			</div>

			<!-- Десктопная сцена -->
			<div class="relative mx-auto hidden aspect-[10/6] w-full max-w-4xl sm:aspect-[16/9] md:block">
				{
					blocks.map((b, i) => {
						const [lx, ty] = anchors[i] ?? [50, 50];
						return (
							<button
								type="button"
								data-open-dialog={`dlg-${b.slug}`}
								data-stage-slug={b.slug}
								data-stage-roam="desktop"
								class:list={[
									'class-stage-walker absolute z-20 flex w-[5.25rem] flex-col items-center rounded-2xl border border-transparent bg-transparent p-1 shadow-none backdrop-blur-none transition hover:border-blue-300/50 hover:bg-slate-900/[0.04] focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 sm:w-28 [transform-style:flat]',
									`class-stage-walker-${i}`,
								]}
								style={`left:${lx}%; top:${ty}%;`}
							>
								<div
									class="class-stage-bubble pointer-events-none absolute bottom-[calc(100%-4px)] left-0 right-0 z-[35] flex justify-center opacity-0 transition-opacity duration-500 ease-out"
									data-stage-bubble=""
									aria-hidden="true"
								>
									<div
										class="class-stage-bubble-panel relative max-w-[min(11rem,calc(100vw-3rem))] rounded-xl border border-slate-200/90 bg-white px-2.5 py-2 text-center text-[10px] font-medium leading-snug text-slate-800 shadow-md sm:text-[11px]"
									>
										<span data-stage-bubble-text=""></span>
									</div>
								</div>
								<div class="h-[4.5rem] w-full sm:h-28">
									<StudentAvatar variant={b.variant} displayName={b.data.displayName} class="h-full w-full" />
								</div>
								<span class="max-w-full truncate px-0.5 text-center text-[10px] font-semibold leading-tight text-slate-800 sm:text-xs">
									{b.data.displayName}
								</span>
							</button>
						);
					})
				}
			</div>
		</div>
	</div>

	<div class="rounded-b-3xl border-t border-slate-200/80 bg-slate-50/70 px-2 py-2 sm:px-4 md:hidden">
		<div class="flex flex-wrap justify-center gap-1 sm:gap-1.5">
			{
				blocks.map((b) => (
					<button
						type="button"
						data-open-dialog={`dlg-${b.slug}`}
						class="rounded-full border border-slate-200/90 bg-white px-2 py-0.5 text-[11px] font-semibold leading-tight text-slate-700 shadow-sm transition hover:border-blue-300/60 hover:bg-blue-50/50 hover:text-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 active:scale-[0.98] sm:px-2.5 sm:text-xs md:py-1"
					>
						{b.data.displayName}
					</button>
				))
			}
		</div>
	</div>
</div>

<style is:global set:html={roamCss + '\n' + roamMobileCss}></style>

<style>
	.class-stage-bubble-panel::after {
		content: '';
		position: absolute;
		left: 50%;
		top: 100%;
		margin-left: -7px;
		border: 7px solid transparent;
		border-top-color: #fff;
	}

	.class-stage-bubble-panel--compact::after {
		margin-left: -5px;
		border-width: 5px;
	}

	.class-stage-walker.is-speaking {
		z-index: 40;
	}

	.class-stage-walker.is-speaking .class-stage-bubble {
		opacity: 1;
	}

	.class-stage-walker-m.is-speaking {
		z-index: 40;
	}

	.class-stage-walker-m.is-speaking .class-stage-bubble {
		opacity: 1;
	}

	@media (prefers-reduced-motion: reduce) {
		.class-stage-walker[class*='class-stage-walker-'] {
			animation: none !important;
			transform: translate(-50%, -50%);
		}

		.class-stage-walker-m[class*='class-stage-walker-m-'] {
			animation: none !important;
			transform: translate(-50%, -50%);
		}
	}
</style>

<style is:global>
	.class-stage-root [data-stage-slug].class-stage-figure-pulse {
		animation: class-stage-figure-pulse 0.75s ease-out;
	}

	@keyframes class-stage-figure-pulse {
		0% {
			box-shadow: 0 0 0 0 rgb(59 130 246 / 0);
		}
		35% {
			box-shadow: 0 0 0 5px rgb(59 130 246 / 0.28);
		}
		100% {
			box-shadow: 0 0 0 0 rgb(59 130 246 / 0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.class-stage-root [data-stage-slug].class-stage-figure-pulse {
			animation: none;
		}
	}
</style>

<script is:inline define:vars={{ speechLines, speechCycleMs: SPEECH_CYCLE_MS }}>
	(function () {
		const mq = window.matchMedia('(min-width: 768px)');
		const mqReduce = window.matchMedia('(prefers-reduced-motion: reduce)');

		function tick() {
			const root = document.querySelector('[data-class-stage]');
			if (!root) return;
			const figures = [
				...root.querySelectorAll(
					mq.matches ? '[data-stage-roam="desktop"]' : '[data-stage-roam="mobile"]'
				),
			];

			const clearAll = () => {
				for (const el of root.querySelectorAll('[data-stage-roam]')) {
					el.classList.remove('is-speaking');
				}
			};

			if (mqReduce.matches || !figures.length) {
				clearAll();
				return;
			}

			const nLines = speechLines.length;
			const seg = speechCycleMs / nLines;
			const t = Date.now() % speechCycleMs;
			const lineIndex = Math.min(Math.floor(t / seg), nLines - 1);
			const n = figures.length;
			const speakerIndex = lineIndex % n;

			figures.forEach((el, i) => {
				const textEl = el.querySelector('[data-stage-bubble-text]');
				if (i === speakerIndex && textEl) {
					textEl.textContent = speechLines[lineIndex];
					el.classList.add('is-speaking');
				} else {
					el.classList.remove('is-speaking');
				}
			});
		}

		const id = window.setInterval(tick, 120);
		tick();
		mq.addEventListener('change', tick);
		mqReduce.addEventListener('change', tick);
		document.addEventListener(
			'astro:before-swap',
			() => {
				window.clearInterval(id);
			},
			{ once: true }
		);
	})();
</script>
