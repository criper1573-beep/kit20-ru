---
import StudentAvatar from './StudentAvatar.astro';
import { buildClassStageWalkerCss } from '../lib/classStageWalkCss';

export interface StageBlock {
	slug: string;
	data: { displayName: string };
	variant: number;
}

interface Props {
	blocks: StageBlock[];
	/** Подсказка по центру сцены (например в админке) */
	pageLead?: string;
}

const { blocks, pageLead } = Astro.props;

const roamCss = buildClassStageWalkerCss();

const anchors: [number, number][] = [
	[18, 22],
	[28, 16],
	[78, 24],
	[68, 34],
	[48, 20],
	[34, 30],
	[58, 46],
	[82, 50],
	[16, 58],
	[30, 72],
	[52, 68],
	[74, 62],
	[40, 48],
	[62, 78],
	[84, 38],
	[24, 40],
];

const SPEECH_CYCLE_MS = 60_000;
const speechLines = [
	'Что светит в том окошке? Восток… и Джульетта — солнце.',
	'О Ромео, Ромео! Забудь отца — я стану твоей.',
	'Ужели ты Ромео? И знал ли ты запретный дом?',
	'Любовь впервые шепнула мне, когда я услышала речь твою.',
	'Как ни зовут меня — сердце узнает твой голос.',
	'Поклянись любовью — с любви слетает клятва.',
	'Не клянись ни в чём: любовь сама себе обет.',
	'Что за шум? Проклята рука, что пролила кровь!',
	'Один день наших вражд — и горе родам нашим!',
	'Прощай… ты останешься в сердце, виновник моего несчастья.',
	'Нож любви хочу занести на имя, что мне мерещится.',
	'Ночь прошла — смотри, как роса с уст твоих…',
	'Уйти? Нет, погибну здесь, где ты впервые обнял меня.',
	'Два дома, равные в чести… где заря смешает их в пепел.',
	'Тише! стража — укройся в сумраке сада.',
	'Окно открыто — лестница луны к нам склонилась.',
	'Не говори «навсегда» — скажи «сегодня», и этого достаточно.',
	'Шаги… это смерть иль мир идёт ко мне?',
	'Пусть имя твоё станет молитвой, которую шепчет ночь.',
	'Снова зовёт занавес — и снова мы встретимся в пьесе…',
];
---

<!--
  Рендерится слотом между шапкой (z-40) и main — z-[45] выше хедера; не внутри main, иначе весь main рисуется под sticky.
-->
<div class="class-page-overlay-root pointer-events-none relative z-[45] min-h-0 w-full" data-class-stage="">
	<div
		class="class-stage-roam-shell pointer-events-none fixed inset-0 z-[55] overflow-hidden"
		style="padding: max(0.5rem, env(safe-area-inset-top, 0px)) max(0.5rem, env(safe-area-inset-right, 0px)) max(0.5rem, env(safe-area-inset-bottom, 0px)) max(0.5rem, env(safe-area-inset-left, 0px));"
	>
		<svg
			class="class-stage-stroke-layer pointer-events-none absolute inset-0 z-[14] h-full w-full"
			aria-hidden="true"
		>
			<path
				id="class-stroke-to-figure"
				fill="none"
				stroke="#d42b2b"
				stroke-width="2.5"
				stroke-linecap="square"
				stroke-linejoin="round"
				opacity="0.9"></path>
		</svg>

		<div
			class="class-stage-watermark pointer-events-none absolute inset-0 z-[12] flex flex-col items-center justify-end px-4 pb-[max(14vh,4.5rem)] text-center sm:justify-center sm:pb-0"
		>
			{
				pageLead && (
					<p class="class-stage-watermark-lead max-w-xl text-sm leading-relaxed sm:text-base">
						{pageLead}
					</p>
				)
			}
		</div>

		<div class="relative z-20 h-full min-h-[12rem] w-full">
			{
				blocks.map((b, i) => {
					const [lx, ty] = anchors[i] ?? [50, 50];
					return (
						<button
							type="button"
							data-open-dialog={`dlg-${b.slug}`}
							data-stage-slug={b.slug}
							data-stage-roam="page"
							class:list={[
								'class-stage-walker-page absolute z-10 flex w-14 flex-col items-center border-[3px] border-transparent bg-transparent p-0.5 shadow-none transition [transform-style:flat] sm:w-[5.25rem] md:w-28',
								`class-stage-walker-${i}`,
								'pointer-events-auto active:bg-ink/[0.05] focus:outline-none focus-visible:ring-2 focus-visible:ring-accent md:hover:border-ink md:hover:bg-muted-surface md:hover:shadow-[var(--shadow-card)]',
							]}
							style={`left:${lx}%; top:${ty}%;`}
						>
							<div
								class="class-stage-bubble pointer-events-none absolute bottom-[calc(100%-2px)] left-0 right-0 z-[25] flex justify-center opacity-0 transition-opacity duration-500 ease-out sm:bottom-[calc(100%-4px)]"
								data-stage-bubble=""
								aria-hidden="true"
							>
								<div
									class="class-stage-bubble-panel class-stage-bubble-panel--compact relative max-w-[min(11rem,calc(100vw-3rem))] border-[3px] border-ink bg-surface px-2 py-1.5 text-center font-display text-[9px] font-normal uppercase leading-tight tracking-wide text-ink shadow-[var(--shadow-card)] sm:px-3 sm:py-2.5 sm:text-[10px] sm:leading-snug md:text-[11px]"
								>
									<span data-stage-bubble-text=""></span>
								</div>
							</div>
							<div class="h-10 w-full sm:h-[4.5rem] md:h-28">
								<StudentAvatar variant={b.variant} displayName={b.data.displayName} class="h-full w-full" />
							</div>
							<span class="mt-0.5 max-w-full truncate px-0.5 text-center font-display text-[10px] font-normal uppercase leading-tight tracking-[0.12em] text-ink sm:text-[11px]">
								{b.data.displayName}
							</span>
						</button>
					);
				})
			}
		</div>
	</div>

</div>

<style is:global set:html={roamCss}></style>

<style>
	.class-page-overlay-root.is-footer-active .class-stage-roam-shell,
	.class-page-overlay-root.is-footer-active > .fixed.bottom-0 {
		opacity: 0;
		pointer-events: none;
	}

	.class-stage-watermark-lead {
		color: rgb(82 82 91 / 0.55);
	}

	.class-stage-bubble-panel::after {
		content: '';
		position: absolute;
		left: 50%;
		top: 100%;
		margin-left: -7px;
		border: 7px solid transparent;
		border-top-color: var(--color-surface);
	}

	.class-stage-bubble-panel--compact::after {
		margin-left: -5px;
		border-width: 5px;
	}

	.class-stage-walker-page.is-speaking {
		z-index: 30;
	}

	.class-stage-walker-page.is-speaking .class-stage-bubble {
		opacity: 1;
	}

	@media (prefers-reduced-motion: reduce) {
		.class-stage-walker-page[class*='class-stage-walker-'] {
			animation: none !important;
			transform: translate(-50%, -50%);
		}
	}
</style>

<style is:global>
	[data-class-stage] [data-stage-slug].class-stage-figure-pulse {
		animation: class-stage-figure-pulse 0.75s ease-out;
	}

	@keyframes class-stage-figure-pulse {
		0% {
			box-shadow: 0 0 0 0 rgb(59 130 246 / 0);
		}
		35% {
			box-shadow: 0 0 0 5px rgb(59 130 246 / 0.28);
		}
		100% {
			box-shadow: 0 0 0 0 rgb(59 130 246 / 0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		[data-class-stage] [data-stage-slug].class-stage-figure-pulse {
			animation: none;
		}
	}
</style>

<script is:inline define:vars={{ speechLines, speechCycleMs: SPEECH_CYCLE_MS }}>
	(function () {
		const mqReduce = window.matchMedia('(prefers-reduced-motion: reduce)');

		function tick() {
			const figures = [...document.querySelectorAll('[data-stage-roam="page"]')];

			const clearAll = () => {
				for (const el of figures) {
					el.classList.remove('is-speaking');
				}
			};

			if (mqReduce.matches || !figures.length) {
				clearAll();
				return;
			}

			const nLines = speechLines.length;
			const seg = speechCycleMs / nLines;
			const t = Date.now() % speechCycleMs;
			const lineIndex = Math.min(Math.floor(t / seg), nLines - 1);
			const n = figures.length;
			const speakerIndex = lineIndex % n;

			figures.forEach((el, i) => {
				const textEl = el.querySelector('[data-stage-bubble-text]');
				if (i === speakerIndex && textEl) {
					textEl.textContent = speechLines[lineIndex];
					el.classList.add('is-speaking');
				} else {
					el.classList.remove('is-speaking');
				}
			});
		}

		const id = window.setInterval(tick, 120);
		tick();
		mqReduce.addEventListener('change', tick);
		document.addEventListener(
			'astro:before-swap',
			() => {
				window.clearInterval(id);
			},
			{ once: true }
		);
	})();
</script>

<script is:inline>
	(function () {
		const root = document.querySelector('[data-class-stage]');
		const path = document.getElementById('class-stroke-to-figure');
		if (!root || !path || !(path instanceof SVGPathElement)) return;
		const isMobile = window.matchMedia('(max-width: 767px)').matches;
		if (isMobile) {
			path.setAttribute('opacity', '0');
			return;
		}
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

		const clearLine = () => {
			path.style.transition = 'none';
			path.style.strokeDasharray = '0';
			path.style.strokeDashoffset = '0';
			path.setAttribute('d', '');
		};

		root.addEventListener('click', (e) => {
			const el = e.target;
			const t = el instanceof Element ? el.closest('[data-open-dialog]') : null;
			if (!t || !root.contains(t)) return;
			const id = t.getAttribute('data-open-dialog');
			if (!id || !id.startsWith('dlg-')) return;
			const rect = t.getBoundingClientRect();
			const tx = rect.left + rect.width / 2;
			const ty = rect.top + rect.height / 2;
			const sx = window.innerWidth * 0.5;
			const sy = window.innerHeight + 24;
			const cx = (sx + tx) / 2;
			const cy = (sy + ty) / 2 - 100;
			path.setAttribute('d', `M ${sx} ${sy} Q ${cx} ${cy} ${tx} ${ty}`);
			const len = path.getTotalLength();
			path.style.strokeDasharray = String(len);
			path.style.strokeDashoffset = String(len);
			path.style.transition = 'none';
			requestAnimationFrame(() => {
				requestAnimationFrame(() => {
					path.style.transition = 'stroke-dashoffset 0.7s ease-out';
					path.style.strokeDashoffset = '0';
				});
			});
		});

		document.addEventListener(
			'close',
			(e) => {
				if (e.target instanceof HTMLDialogElement) clearLine();
			},
			true
		);
	})();
</script>

<script is:inline>
	(function () {
		const root = document.querySelector('[data-class-stage]');
		if (!root) return;

		function initFooterObserver() {
			const footer = document.querySelector('footer');
			if (!footer) return false;

			const io = new IntersectionObserver(
				(entries) => {
					for (const entry of entries) {
						root.classList.toggle('is-footer-active', entry.isIntersecting);
					}
				},
				{ threshold: 0.01 }
			);

			io.observe(footer);
			document.addEventListener(
				'astro:before-swap',
				() => {
					io.disconnect();
				},
				{ once: true }
			);
			return true;
		}

		// Компонент рендерится раньше футера, поэтому делаем ленивую инициализацию.
		if (initFooterObserver()) return;
		window.addEventListener(
			'load',
			() => {
				initFooterObserver();
			},
			{ once: true }
		);
	})();
</script>
